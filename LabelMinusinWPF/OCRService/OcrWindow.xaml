<Window
    x:Class="LabelMinusinWPF.OCRService.OcrWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    Title="OCR识别"
    Width="1000"
    Height="600"
    Background="{DynamicResource MaterialDesignPaper}"
    WindowStartupLocation="CenterScreen">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="4*" />
        </Grid.ColumnDefinitions>

        <!--  左侧：截图显示  -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock
                    Grid.Row="0"
                    Margin="16,16,16,8"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                    Text="截图预览" />

                <Border Grid.Row="1" Background="{DynamicResource MaterialDesignCardBackground}" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="1">
                    <Viewbox Stretch="Uniform">
                        <Image x:Name="ScreenshotImage" MouseMove="OnScreenshotMove" />
                    </Viewbox>
                </Border>
            </Grid>
        </Border>

        <!--  分割线  -->
        <GridSplitter
            Grid.Column="1"
            Width="5"
            HorizontalAlignment="Center"
            VerticalAlignment="Stretch"
            Background="RoyalBlue" />

        <!--  右侧：WebView2浏览器  -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock
                x:Name="WebsiteTitle"
                Grid.Row="0"
                Margin="16,16,16,8"
                Foreground="{DynamicResource MaterialDesignBody}"
                Style="{StaticResource MaterialDesignHeadline6TextBlock}"
                Text="识别网站" />

            <Grid x:Name="WebBrowserHost" Grid.Row="1" />
        </Grid>
    </Grid>
</Window>
