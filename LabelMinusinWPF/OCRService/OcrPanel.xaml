<UserControl
    x:Class="LabelMinusinWPF.OCRService.OcrPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Width="230"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Border
        Padding="8"
        Background="{DynamicResource MaterialDesignPaper}"
        BorderBrush="{DynamicResource MaterialDesignDivider}"
        BorderThickness="1"
        CornerRadius="6"
        SnapsToDevicePixels="True">
        <StackPanel Orientation="Vertical">
            <!--  1. 网站选择行：文字已内嵌  -->
            <TextBlock
                Margin="0,0,0,8"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{DynamicResource MaterialDesignBody}"
                Text="字体识别" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    x:Name="WebsiteSelector"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    materialDesign:HintAssist.Hint="网站"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    SelectedIndex="0" />

                <Button
                    x:Name="WebOcrButton"
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Click="OpenWebOcr_Click"
                    Tag="Magnify"
                    ToolTip="用剪贴板截图打开外部字体识别网站" />
            </Grid>

            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <TextBlock
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Text="内容识别" />

                <ToggleButton
                    x:Name="ScreenshotOcrToggle"
                    Margin="8,0,0,0"
                    VerticalAlignment="Center"
                    Tag="Ocr"
                    ToolTip="开启后，截图选区会自动 OCR 并在当前图片新建标签">
                    <ToggleButton.ContentTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon x:Name="PartIcon" Width="40" Height="40" Kind="{Binding Tag, RelativeSource={RelativeSource AncestorType=ButtonBase}}" />
                            </StackPanel>
                        </DataTemplate>
                    </ToggleButton.ContentTemplate>
                </ToggleButton>
            </StackPanel>

            <ComboBox
                x:Name="EngineSelector"
                Margin="0,0,0,8"
                HorizontalAlignment="Stretch"
                VerticalAlignment="Center"
                Foreground="{DynamicResource MaterialDesignBody}">
                <ComboBoxItem Content="Paddle-ocr" IsSelected="True" Tag="Paddle" />
                <ComboBoxItem Content="manga-ocr" Tag="Manga" />
            </ComboBox>

            <!--  “一键”核心功能行  -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="AutoDotButton"
                    Grid.Column="0"
                    Height="40"
                    Margin="2,0"
                    Click="AutoDot_Click"
                    Content=""
                    Tag="Numeric1Circle"
                    ToolTip="使用 PP-OCRv6 检测文字区域，并在右上角创建位置标签" />

                <Button
                    x:Name="BatchRecognizeButton"
                    Grid.Column="1"
                    Height="40"
                    Margin="2,0"
                    Click="BatchRecognize_Click"
                    Content=""
                    Tag="TextRecognition"
                    ToolTip="使用当前选择的 OCR 模型识别文字并创建标签" />
            </Grid>

            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="SetupButton"
                    Grid.Column="0"
                    Height="40"
                    Margin="2,0"
                    Click="SetupOcrEnv_Click"
                    Tag="Cog"
                    ToolTip="配置 OCR 模型和日文识别环境" />

                <Button
                    x:Name="HelpButton"
                    Grid.Column="1"
                    Height="40"
                    Margin="2,0"
                    Click="OcrHelp_Click"
                    Tag="HelpCircleOutline"
                    ToolTip="OCR 说明" />
            </Grid>
        </StackPanel>
    </Border>
</UserControl>
