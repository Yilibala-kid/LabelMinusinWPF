<UserControl
    x:Class="LabelMinusinWPF.OCRService.OcrPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:ocr="clr-namespace:LabelMinusinWPF.OCRService"
    Width="230"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility" />
    </UserControl.Resources>

    <Border
        Padding="8"
        Background="{DynamicResource MaterialDesignPaper}"
        BorderBrush="{DynamicResource MaterialDesignDivider}"
        BorderThickness="1"
        CornerRadius="6"
        SnapsToDevicePixels="True">
        <StackPanel Orientation="Vertical">
            <!--  1. 网站选择行：文字已内嵌  -->
            <TextBlock
                Margin="0,0,0,8"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{DynamicResource MaterialDesignBody}"
                Text="字体识别" />
            <Grid Margin="0,0,0,12">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <ComboBox
                    x:Name="WebsiteSelector"
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    materialDesign:HintAssist.Hint="网站"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    ItemsSource="{x:Static ocr:OcrConstants.OcrWebsiteKeys}"
                    SelectedIndex="0" />

                <Button
                    x:Name="WebOcrButton"
                    Grid.Column="1"
                    Margin="8,0,0,0"
                    Click="OpenWebOcr_Click"
                    Tag="Magnify"
                    ToolTip="将当前截图放到网站中识别" />
            </Grid>

            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <TextBlock
                    Grid.Column="0"
                    VerticalAlignment="Center"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource MaterialDesignBody}"
                    Text="内容识别" />

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <ComboBox
                        x:Name="EngineSelector"
                        Width="60"
                        VerticalAlignment="Center"
                        Foreground="{DynamicResource MaterialDesignBody}">
                        <ComboBoxItem Content="中英" />
                        <ComboBoxItem Content="日文" IsSelected="True" />
                    </ComboBox>
                    <ToggleButton
                        x:Name="ScreenshotOcrToggle"
                        Margin="4,0,0,0"
                        VerticalAlignment="Center"
                        Tag="Ocr"
                        ToolTip="开启后截图自动识别内容并新建标签">
                        <ToggleButton.ContentTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal">
                                    <materialDesign:PackIcon x:Name="PartIcon" Width="40" Height="40" Kind="{Binding Tag, RelativeSource={RelativeSource AncestorType=ButtonBase}}" />
                                </StackPanel>
                            </DataTemplate>
                        </ToggleButton.ContentTemplate>
                    </ToggleButton>


                </StackPanel>
            </Grid>

            <!--  “一键”核心功能行：横向三列  -->
            <Grid Margin="0,0,0,8">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Button
                    x:Name="AutoDotButton"
                    Grid.Column="0"
                    Height="40"
                    Margin="2,0"
                    Click="AutoDot_Click"
                    Content=""
                    Tag="Numeric1Circle"
                    ToolTip="使用 PaddleOCR 在文字区域右上角打点" />

                <Button
                    x:Name="BatchCnEnButton"
                    Grid.Column="1"
                    Height="40"
                    Margin="2,0"
                    Click="BatchCnEn_Click"
                    Content=""
                    Tag="Alphabetical"
                    ToolTip="使用 PaddleOCR v5 进行中/英文识别+打点" />

                <Button
                    x:Name="BatchJpButton"
                    Grid.Column="2"
                    Height="40"
                    Margin="2,0"
                    Click="BatchJp_Click"
                    Content=""
                    Tag="Translate"
                    ToolTip="使用 manga-ocr 进行日文检测+打点" />
            </Grid>

            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button x:Name="SetupButton" Click="SetupOcrEnv_Click" Tag="Cog" ToolTip="配置环境" />
                <Button
                    x:Name="HelpButton"
                    Margin="4,0,0,0"
                    Click="OcrHelp_Click"
                    Tag="HelpCircleOutline"
                    ToolTip="OCR 说明" />
            </StackPanel>
        </StackPanel>
    </Border>
</UserControl>
