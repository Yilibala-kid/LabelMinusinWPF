<UserControl x:Class="LabelMinusinWPF.ImageReView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LabelMinusinWPF"
             mc:Ignorable="d" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesignPaper}"
             d:DesignHeight="800" d:DesignWidth="1200">
    <UserControl.Resources>
        <Style TargetType="StackPanel">
            <Setter Property="Orientation"
            Value= "Horizontal" />
        </Style>
        
        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment"
                    Value= "Center" />
            <Setter Property="HorizontalAlignment"
                    Value= "Center" />
        </Style>
    </UserControl.Resources>
<UserControl.DataContext>
    <local:MainViewModel />
</UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 更换图片 -->
            <Button VerticalAlignment="Bottom" Grid.Column="0" Margin="2" Padding="8,4" ToolTip="更换当前图片&#x0A;(不影响图集)">
                <materialDesign:PackIcon Kind="FileImage"/>
            </Button>

            <UniformGrid Grid.Column="1" Rows="2" Columns="1" Margin="5,0">
                <!-- 选择图片/压缩包 -->
                <Button Style="{StaticResource IconButtonStyle}"
                        HorizontalAlignment="Left"
                            Tag="ImageMultiple" 
                            Content="选择图片/压缩包"
                            ToolTip="支持多选图片或单个压缩包"/>
                <!-- 选择文件夹 -->
                <Button Style="{StaticResource IconButtonStyle}"
                        HorizontalAlignment="Left"
                            Tag="FolderOpen"
                            Content="选择文件夹"
                            ToolTip="文件夹中的所有图片"/>
            </UniformGrid>

            <StackPanel Grid.Column="2" VerticalAlignment="Center" >
                <!-- 截图 -->
                <Button Style="{StaticResource IconButtonStyle}" Height="60" Width="100"
                        HorizontalAlignment="Left"
                            Tag="Camera"
                            Content="截图(Q)"
                            ToolTip="截图自动复制到剪贴板"/>

                <ComboBox VerticalAlignment="Bottom" Height="40"  Width="180" Margin="0,5"/>
                <!-- 上一张 -->
                <Button Height="60" Margin="5" Padding="8,4" ToolTip="上一张">
                    <materialDesign:PackIcon Kind="ArrowUp" Width="30" Height="36"/>
                </Button>
                <!-- 下一张 -->
                <Button Height="60" Margin="5" Padding="8,4" ToolTip="下一张">
                    <materialDesign:PackIcon Kind="ArrowDown" Width="30" Height="36"/>
                </Button>
            </StackPanel>

            <UniformGrid Grid.Column="3" Rows="2" Columns="1" Margin="5,0">
                <!-- 选择图片/压缩包 -->
                <Button Style="{StaticResource IconButtonStyle}"
                        HorizontalAlignment="Right"
                            Tag="ImageMultiple" 
                            Content="选择图片/压缩包"
                            ToolTip="支持多选图片或单个压缩包"/>
                <!-- 选择文件夹 -->
                <Button Style="{StaticResource IconButtonStyle}"
                        HorizontalAlignment="Right"
                            Tag="FolderOpen"
                            Content="选择文件夹"
                            ToolTip="文件夹中的所有图片"/>
            </UniformGrid>

            <!-- 更换图片 -->
            <Button VerticalAlignment="Bottom" Grid.Column="4" Margin="2" Padding="8,4" ToolTip="更换当前图片&#x0A;(不影响图集)">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileImage"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="Transparent">
                <Image x:Name="LeftImage" Stretch="Uniform"/>
            </Grid>

            <GridSplitter Grid.Column="1" 
              HorizontalAlignment="Stretch" 
              Width="6">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                <Ellipse Fill="White" Width="2" Height="2" Margin="0,2"/>
                                <Ellipse Fill="White" Width="2" Height="2" Margin="0,2"/>
                                <Ellipse Fill="White" Width="2" Height="2" Margin="0,2"/>
                            </StackPanel>
                        </Grid>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>

            <Grid Grid.Column="2" Background="Transparent">
                <Image x:Name="RightImage" Stretch="Uniform"/>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 适应屏幕 -->
            <Button Grid.Column="0" 
                    Style="{StaticResource IconButtonStyle}"
                    HorizontalAlignment="Left"
                    Tag="FitToPage"
                    Content="适应屏幕"
                    ToolTip=""/>
            <!-- 打开截图文件夹 -->
            <Button Grid.Column="1" 
                    Style="{StaticResource IconButtonStyle}"
                    HorizontalAlignment="Left"
                    Tag="FolderImage"
                    Content="打开截图文件夹"
                    ToolTip="存放所有截图，关闭程序后清空"/>

            <TextBlock Grid.Column="2" Text="左键标注&#x0a;右键清空" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5,0"/>
            <Border Grid.Column="3" Width="80" Height="40" Background="#FFDAB9" BorderBrush="#888" BorderThickness="1" Margin="5,0"/>

            <!-- 同步显示 -->
            <Button Grid.Column="4" Background="#90EE90"
                    Style="{StaticResource IconButtonStyle}"
                    HorizontalAlignment="Left"
                    Tag="Sync"
                    Content="同步显示"
                    ToolTip="可以同步拖动两侧图片"/>
            <StackPanel Grid.Column="5" Orientation="Horizontal">
                <!-- 清空图片 -->
                <Button Style="{StaticResource IconButtonStyle}"
                    HorizontalAlignment="Left"
                    Tag="Delete"
                    Content="清空图片"
                    ToolTip="重新选择"/>
                <!-- 退出图校 -->
                <Button Style="{StaticResource IconButtonStyle}"
                    x:Name="ExitBtn" Background="PaleVioletRed" Foreground="White"
                    HorizontalAlignment="Left"
                    Tag="Close" 
                    Content="退出图校"
                    ToolTip="不会清空当前图片"
                    Click="ExitBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>