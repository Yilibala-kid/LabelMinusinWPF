<UserControl
    x:Class="LabelMinusinWPF.ImageReView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LabelMinusinWPF"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource MaterialDesignPaper}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <UserControl.DataContext>
        <local:ImageReviewVM />
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="32*" />
                <ColumnDefinition Width="325*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="357*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 更换图片 -->
            <Button
                Grid.Column="0"
                Margin="2,2,2,2"
                Padding="8,4"
                ToolTip="更换当前图片&#x0A;(不影响图集)"
                Click="LeftChangePic_Click">
                <materialDesign:PackIcon Kind="FileImage" />
            </Button>

            <UniformGrid
                Grid.Column="1"
                Grid.ColumnSpan="2"
                Margin="5,0,5,0"
                Rows="1"
                Columns="2">
                <!-- 选择图片/压缩包 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="ImageMultiple"
                    Content="选择图片/压缩包"
                    ToolTip="支持多选图片或单个压缩包"
                    Command="{Binding LeftImageVM.OpenImageOrZipCommand}" />
                <!-- 选择文件夹 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="FolderOpen"
                    Content="选择文件夹"
                    ToolTip="文件夹中的所有图片"
                    Command="{Binding LeftImageVM.OpenImageFolderCommand}" />
            </UniformGrid>

            <StackPanel Grid.Column="3" VerticalAlignment="Center">
                <!-- 截图 -->
                <ToggleButton
                    x:Name="DualScreenShot"
                    Width="100"
                    HorizontalAlignment="Left"
                    Style="{StaticResource IconToggleButtonStyle}"
                    Tag="Camera"
                    Content="截图(Q)"
                    ToolTip="截图自动复制到剪贴板"
                    IsChecked="{Binding IsScreenShotEnabled}" />
                <ComboBox
                    x:Name="DualNameCombobox"
                    Width="180"
                    Height="30"
                    ItemsSource="{Binding AllImageNames}"
                    SelectedItem="{Binding SelectedMergedName}"
                    ToolTip="选择图片 (并在左右两侧同步显示)" />
                <!-- 上一张 -->
                <Button ToolTip="上一张" Command="{Binding PreviousImageCommand}">
                    <materialDesign:PackIcon Width="30" Height="30" Kind="ArrowUp" />
                </Button>
                <!-- 下一张 -->
                <Button ToolTip="下一张" Command="{Binding NextImageCommand}">
                    <materialDesign:PackIcon Width="30" Height="30" Kind="ArrowDown" />
                </Button>
            </StackPanel>

            <UniformGrid
                Grid.Column="4"
                Margin="5,0,5,0"
                Rows="1"
                Columns="2">
                <!-- 选择文件夹 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="FolderOpen"
                    Content="选择文件夹"
                    ToolTip="文件夹中的所有图片"
                    Command="{Binding RightImageVM.OpenImageFolderCommand}" />
                <!-- 选择图片/压缩包 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="ImageMultiple"
                    Content="选择图片/压缩包"
                    ToolTip="支持多选图片或单个压缩包"
                    Command="{Binding RightImageVM.OpenImageOrZipCommand}" />

            </UniformGrid>

            <!-- 更换图片 -->
            <Button
                Grid.Column="5"
                Margin="2,2,2,2"
                Padding="8,4"
                ToolTip="更换当前图片&#x0A;(不影响图集)"
                Click="RightChangePic_Click">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileImage" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- 左侧图片 -->
            <local:ImagewithLabelShow
                x:Name="LeftPicView"
                Grid.Column="0"
                DataContext="{Binding LeftImageVM.SelectedImage}"
                IsIndexVisible="False"
                IsTextVisible="False"
                OnlySEE="True"
                ZoomScale="{Binding DataContext.LeftZoom, RelativeSource={RelativeSource AncestorType=Grid}, Mode=TwoWay}"
                OffsetX="{Binding DataContext.LeftOffsetX, RelativeSource={RelativeSource AncestorType=Grid}, Mode=TwoWay}"
                OffsetY="{Binding DataContext.LeftOffsetY, RelativeSource={RelativeSource AncestorType=Grid}, Mode=TwoWay}"
                IsScreenShotMode="{Binding IsChecked, ElementName=DualScreenShot}"
                IsSyncRequired="True" />


            <!--<GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse
                                    Width="2"
                                    Height="2"
                                    Margin="0,2"
                                    Fill="White" />
                                <Ellipse
                                    Width="2"
                                    Height="2"
                                    Margin="0,2"
                                    Fill="White" />
                                <Ellipse
                                    Width="2"
                                    Height="2"
                                    Margin="0,2"
                                    Fill="White" />
                            </StackPanel>
                        </Grid>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>-->
            <!-- 右侧图片 -->
            <local:ImagewithLabelShow
                x:Name="RightPicView"
                Grid.Column="2"
                DataContext="{Binding RightImageVM.SelectedImage}"
                IsIndexVisible="False"
                IsTextVisible="False"
                OnlySEE="True"
                ZoomScale="{Binding DataContext.RightZoom, RelativeSource={RelativeSource AncestorType=Grid}, Mode=TwoWay}"
                OffsetX="{Binding DataContext.RightOffsetX, RelativeSource={RelativeSource AncestorType=Grid}, Mode=TwoWay}"
                OffsetY="{Binding DataContext.RightOffsetY, RelativeSource={RelativeSource AncestorType=Grid}, Mode=TwoWay}"
                IsScreenShotMode="{Binding IsChecked, ElementName=DualScreenShot}"
                IsSyncRequired="True" />

        </Grid>

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 适应屏幕 -->
            <StackPanel Grid.Column="0">
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="FitToPage"
                    Content="适应屏幕"
                    ToolTip="恢复视图"
                    Command="{Binding ResetSyncCommand}" />
                <!-- 打开截图文件夹 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="FolderImage"
                    Content="截图文件夹"
                    ToolTip="存放所有截图，关闭程序后清空"
                    Click="OpenScreenshotFolder_Click" />
            </StackPanel>



            <StackPanel Grid.Column="2">
                <!-- 截图编辑控件 -->
                <StackPanel>
                    <Border
                        x:Name="ThumbBorder"
                        Width="80"
                        Height="30"
                        Margin="5,0"
                        BorderBrush="#888"
                        BorderThickness="1"
                        MouseEnter="ThumbBorder_MouseEnter"
                        MouseLeave="ThumbBorder_MouseLeave">
                        <Image x:Name="ImgThumb" Stretch="Fill" />

                    </Border>

                    <Popup
                        x:Name="PreviewPopup"
                        PlacementTarget="{Binding ElementName=ThumbBorder}"
                        Placement="Top"
                        StaysOpen="True"
                        AllowsTransparency="True"
                        PopupAnimation="Fade"
                        VerticalOffset="-10">
                        <Border Padding="2" Background="RoyalBlue">
                            <Grid x:Name="DrawingContainer" Background="Black">
                                <Image x:Name="EditImage" Stretch="Uniform" />
                                <InkCanvas x:Name="InkEditor" Background="Transparent" EditingMode="Ink">
                                    <InkCanvas.DefaultDrawingAttributes>
                                        <DrawingAttributes
                                            Width="5"
                                            Height="5"
                                            FitToCurve="True"
                                            Color="Red" />
                                    </InkCanvas.DefaultDrawingAttributes>
                                </InkCanvas>
                            </Grid>
                        </Border>
                    </Popup>
                </StackPanel>


                <!-- 同步显示 -->
                <ToggleButton
                    HorizontalAlignment="Left"
                    Style="{StaticResource IconToggleButtonStyle}"
                    Tag="Sync"
                    Content="同步显示"
                    ToolTip="可以同步拖动两侧图片"
                    IsChecked="{Binding IsSyncEnabled}" />
                <Button
                    Grid.Column="4"
                    HorizontalAlignment="Left"
                    Style="{StaticResource IconButtonStyle}"
                    Tag="SwapHorizontal"
                    Content="交换显示"
                    ToolTip="交换两张图片的显示"
                    Command="{Binding SwapImagesCommand}" />
            </StackPanel>
            <StackPanel Grid.Column="4">
                <!-- 清空图片 -->
                <Button
                    HorizontalAlignment="Left"
                    Style="{StaticResource IconButtonStyle}"
                    Tag="Delete"
                    Content="清空图片"
                    ToolTip="重新选择"
                    Command="{Binding ClearImagesCommand}" />
                <!-- 退出图校 -->
                <Button
                    x:Name="ExitBtn"
                    HorizontalAlignment="Left"
                    Style="{StaticResource IconButtonStyle}"
                    Background="PaleVioletRed"
                    Foreground="White"
                    Tag="Close"
                    Content="退出图校"
                    ToolTip="不会清空当前图片"
                    Click="ExitBtn_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>