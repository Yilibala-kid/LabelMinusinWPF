<UserControl
    x:Class="LabelMinusinWPF.ImageReView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:LabelMinusinWPF"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    d:DesignHeight="800"
    d:DesignWidth="1200"
    Background="{DynamicResource MaterialDesignPaper}"
    mc:Ignorable="d">
    <UserControl.Resources>
        <Style TargetType="StackPanel">
            <Setter Property="Orientation" Value="Horizontal" />
        </Style>

        <Style TargetType="TextBlock">
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="HorizontalAlignment" Value="Center" />
        </Style>
    </UserControl.Resources>
    <UserControl.DataContext>
        <local:ImageReviewVM />
    </UserControl.DataContext>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 更换图片 -->
            <Button
                Grid.Column="0"
                Margin="2"
                Padding="8,4"
                VerticalAlignment="Bottom"
                ToolTip="更换当前图片&#x0A;(不影响图集)">
                <materialDesign:PackIcon Kind="FileImage" />
            </Button>

            <UniformGrid
                Grid.Column="1"
                Margin="5,0"
                Rows="1"
                Columns="2">
                <!-- 选择图片/压缩包 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="ImageMultiple"
                    Content="选择图片/压缩包"
                    ToolTip="支持多选图片或单个压缩包"
                    Command="{Binding LeftImageVM.OpenImageOrZipCommand}" />
                <!-- 选择文件夹 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="FolderOpen"
                    Content="选择文件夹"
                    ToolTip="文件夹中的所有图片"
                    Command="{Binding LeftImageVM.OpenImageFolderCommand}" />
            </UniformGrid>

            <StackPanel Grid.Column="2" VerticalAlignment="Center">
                <!-- 截图 -->
                <Button
                    Width="100"
                    HorizontalAlignment="Left"
                    Style="{StaticResource IconButtonStyle}"
                    Tag="Camera"
                    Content="截图(Q)"
                    ToolTip="截图自动复制到剪贴板" />

                <ComboBox Width="180" Height="40" Margin="0,5" />
                <!-- 上一张 -->
                <Button Margin="5" Padding="8,4" ToolTip="上一张">
                    <materialDesign:PackIcon Width="30" Height="36" Kind="ArrowUp" />
                </Button>
                <!-- 下一张 -->
                <Button Margin="5" Padding="8,4" ToolTip="下一张">
                    <materialDesign:PackIcon Width="30" Height="36" Kind="ArrowDown" />
                </Button>
            </StackPanel>

            <UniformGrid
                Grid.Column="3"
                Margin="5,0"
                Rows="1"
                Columns="2">
                <!-- 选择文件夹 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="FolderOpen"
                    Content="选择文件夹"
                    ToolTip="文件夹中的所有图片"
                    Command="{Binding RightImageVM.OpenImageFolderCommand}" />
                <!-- 选择图片/压缩包 -->
                <Button
                    Style="{StaticResource IconButtonStyle}"
                    Tag="ImageMultiple"
                    Content="选择图片/压缩包"
                    ToolTip="支持多选图片或单个压缩包"
                    Command="{Binding RightImageVM.OpenImageOrZipCommand}" />

            </UniformGrid>

            <!-- 更换图片 -->
            <Button
                Grid.Column="4"
                Margin="2"
                Padding="8,4"
                VerticalAlignment="Bottom"
                ToolTip="更换当前图片&#x0A;(不影响图集)">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileImage" />
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="5" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>
            <!-- 左侧图片 -->
            <Grid Grid.Column="0">
                <local:ImagewithLabelShow
                    x:Name="LeftPicView"
                    DataContext="{Binding LeftImageVM.SelectedImage}"
                    IsIndexVisible="False"
                    IsTextVisible="False" />
            </Grid>

            <GridSplitter Grid.Column="1" Width="6" HorizontalAlignment="Stretch">
                <GridSplitter.Template>
                    <ControlTemplate TargetType="GridSplitter">
                        <Grid Background="{TemplateBinding Background}">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <Ellipse
                                    Width="2"
                                    Height="2"
                                    Margin="0,2"
                                    Fill="White" />
                                <Ellipse
                                    Width="2"
                                    Height="2"
                                    Margin="0,2"
                                    Fill="White" />
                                <Ellipse
                                    Width="2"
                                    Height="2"
                                    Margin="0,2"
                                    Fill="White" />
                            </StackPanel>
                        </Grid>
                    </ControlTemplate>
                </GridSplitter.Template>
            </GridSplitter>
            <!-- 右侧图片 -->
            <Grid Grid.Column="2">
                <local:ImagewithLabelShow
                    x:Name="RightPicView"
                    DataContext="{Binding RightImageVM.SelectedImage}"
                    IsIndexVisible="False"
                    IsTextVisible="False" />
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- 适应屏幕 -->
            <Button
                Grid.Column="0"
                HorizontalAlignment="Left"
                Style="{StaticResource IconButtonStyle}"
                Tag="FitToPage"
                Content="适应屏幕"
                ToolTip="" />
            <!-- 打开截图文件夹 -->
            <Button
                Grid.Column="1"
                HorizontalAlignment="Left"
                Style="{StaticResource IconButtonStyle}"
                Tag="FolderImage"
                Content="截图文件夹"
                ToolTip="存放所有截图，关闭程序后清空" />

            <TextBlock
                Grid.Column="2"
                Margin="5,0"
                HorizontalAlignment="Right"
                VerticalAlignment="Center"
                Text="左键标注&#x0a;右键清空" />
            <Border
                Grid.Column="3"
                Width="80"
                Height="40"
                Margin="5,0"
                Background="#FFDAB9"
                BorderBrush="#888"
                BorderThickness="1" />

            <!-- 同步显示 -->
            <ToggleButton
                Grid.Column="4"
                HorizontalAlignment="Left"
                Style="{StaticResource IconToggleButtonStyle}"
                Tag="Sync"
                Content="同步显示"
                ToolTip="可以同步拖动两侧图片" />
            <StackPanel Grid.Column="5" Orientation="Horizontal">
                <!-- 清空图片 -->
                <Button
                    HorizontalAlignment="Left"
                    Style="{StaticResource IconButtonStyle}"
                    Tag="Delete"
                    Content="清空图片"
                    ToolTip="重新选择" />
                <!-- 退出图校 -->
                <Button
                    x:Name="ExitBtn"
                    HorizontalAlignment="Left"
                    Style="{StaticResource IconButtonStyle}"
                    Background="PaleVioletRed"
                    Foreground="White"
                    Tag="Close"
                    Content="退出图校"
                    ToolTip="不会清空当前图片"
                    Click="ExitBtn_Click" />
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>