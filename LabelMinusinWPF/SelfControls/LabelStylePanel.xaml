<UserControl
    x:Class="LabelMinusinWPF.SelfControls.LabelStylePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:LabelMinusinWPF.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sc="clr-namespace:LabelMinusinWPF.SelfControls"
    Width="220"
    d:DesignHeight="450"
    d:DesignWidth="220"
    mc:Ignorable="d">
    <UserControl.Resources>
        <common:EnumToBooleanConverter x:Key="EnumToBoolConverter" />
    </UserControl.Resources>
    <StackPanel Orientation="Vertical" TextElement.Foreground="{DynamicResource MaterialDesignBody}">
        <!--  标签点样式  -->
        <TextBlock Margin="16,16,16,8" FontWeight="SemiBold" Opacity="0.8" Text="标签点样式" />
        <StackPanel Margin="16,0,16,8" Orientation="Horizontal">
            <RadioButton GroupName="DotStyle" IsChecked="{Binding DotStyle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Circle, Mode=TwoWay}" Tag="Circle" />
            <RadioButton GroupName="DotStyle" IsChecked="{Binding DotStyle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Square, Mode=TwoWay}" Tag="Square" />
            <RadioButton GroupName="DotStyle" IsChecked="{Binding DotStyle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Transparent, Mode=TwoWay}" Tag="Select" />
        </StackPanel>

        <!--  文字背景颜色  -->
        <TextBlock Margin="16,0,16,8" FontWeight="SemiBold" Opacity="0.8" Text="背景颜色" />
        <StackPanel Margin="16,0,16,8" Orientation="Horizontal">
            <Button Background="White" Command="{Binding SetBackgroundColorCommand}" CommandParameter="White" Style="{StaticResource ColorPickerButtonStyle}" />
            <Button Background="Black" Command="{Binding SetBackgroundColorCommand}" CommandParameter="Black" Style="{StaticResource ColorPickerButtonStyle}" />
            <Button Background="RoyalBlue" Command="{Binding SetBackgroundColorCommand}" CommandParameter="RoyalBlue" Style="{StaticResource ColorPickerButtonStyle}" />
        </StackPanel>

        <!--  文字背景透明度  -->
        <TextBlock Margin="16,8,16,4" FontWeight="SemiBold" Opacity="0.8" Text="背景透明度" />
        <Slider
            Margin="16,0,16,8"
            IsSnapToTickEnabled="True"
            Maximum="1"
            Minimum="0"
            TickFrequency="0.1"
            Value="{Binding TextBackgroundOpacity, Mode=TwoWay}" />

        <!--  文字前景颜色  -->
        <TextBlock Margin="16,0,16,8" FontWeight="SemiBold" Opacity="0.8" Text="文字颜色" />
        <StackPanel Margin="16,0,16,8" Orientation="Horizontal">
            <Button Background="White" Command="{Binding SetForegroundColorCommand}" CommandParameter="White" Style="{StaticResource ColorPickerButtonStyle}" />
            <Button Background="Black" Command="{Binding SetForegroundColorCommand}" CommandParameter="Black" Style="{StaticResource ColorPickerButtonStyle}" />
            <Button Background="RoyalBlue" Command="{Binding SetForegroundColorCommand}" CommandParameter="RoyalBlue" Style="{StaticResource ColorPickerButtonStyle}" />
        </StackPanel>

        <!--  标签缩放  -->
        <TextBlock Margin="16,0,16,8" FontWeight="SemiBold" Opacity="0.8" Text="标签缩放" />
        <StackPanel Margin="16,0,16,8" Orientation="Horizontal">
            <Button Command="{Binding ZoomInLabelCommand}" Tag="Plus" ToolTip="放大标签" />
            <Button Command="{Binding ZoomOutLabelCommand}" Tag="Minus" ToolTip="缩小标签" />


        </StackPanel>

        <Button
            Margin="16,0,16,8"
            Background="RoyalBlue"
            Command="{Binding ResetToDefaultsCommand}"
            Content="恢复默认样式"
            FontWeight="Bold"
            Tag="Restore" />
    </StackPanel>
</UserControl>
