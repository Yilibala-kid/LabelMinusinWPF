<UserControl
    x:Class="LabelMinusinWPF.SelfControls.LabelStylePanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:common="clr-namespace:LabelMinusinWPF.Common"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:media="clr-namespace:System.Windows.Media;assembly=PresentationCore"
    xmlns:sc="clr-namespace:LabelMinusinWPF.SelfControls"
    Width="230"
    d:DesignHeight="450"
    d:DesignWidth="230"
    mc:Ignorable="d">
    <UserControl.Resources>
        <common:EnumToBooleanConverter x:Key="EnumToBoolConverter" />
        <Style x:Key="BackgroundColorPickerButtonStyle" BasedOn="{StaticResource ColorPickerButtonStyle}" TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding TextBackgroundColor}" Value="{x:Static media:Colors.White}" />
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="White" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Tag" Value="Selected" />
                    <Setter Property="Panel.ZIndex" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="0" Color="RoyalBlue" />
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding TextBackgroundColor}" Value="{x:Static media:Colors.Black}" />
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="Black" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Tag" Value="Selected" />
                    <Setter Property="Panel.ZIndex" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="0" Color="RoyalBlue" />
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding TextBackgroundColor}" Value="{x:Static media:Colors.RoyalBlue}" />
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="RoyalBlue" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Tag" Value="Selected" />
                    <Setter Property="Panel.ZIndex" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="0" Color="RoyalBlue" />
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="ForegroundColorPickerButtonStyle" BasedOn="{StaticResource ColorPickerButtonStyle}" TargetType="Button">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5" />
            <Style.Triggers>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding TextForegroundColor}" Value="{x:Static media:Colors.White}" />
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="White" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Tag" Value="Selected" />
                    <Setter Property="Panel.ZIndex" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="0" Color="RoyalBlue" />
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding TextForegroundColor}" Value="{x:Static media:Colors.Black}" />
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="Black" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Tag" Value="Selected" />
                    <Setter Property="Panel.ZIndex" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="0" Color="RoyalBlue" />
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding TextForegroundColor}" Value="{x:Static media:Colors.RoyalBlue}" />
                        <Condition Binding="{Binding CommandParameter, RelativeSource={RelativeSource Self}}" Value="RoyalBlue" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Tag" Value="Selected" />
                    <Setter Property="Panel.ZIndex" Value="1" />
                    <Setter Property="RenderTransform">
                        <Setter.Value>
                            <ScaleTransform ScaleX="1.12" ScaleY="1.12" />
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Effect">
                        <Setter.Value>
                            <DropShadowEffect BlurRadius="10" Opacity="0.5" ShadowDepth="0" Color="RoyalBlue" />
                        </Setter.Value>
                    </Setter>
                </MultiDataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>
    <Border
        Padding="8"
        Background="{DynamicResource MaterialDesignPaper}"
        BorderBrush="{DynamicResource MaterialDesignDivider}"
        BorderThickness="1"
        CornerRadius="6"
        SnapsToDevicePixels="True">
        <StackPanel Orientation="Vertical" TextElement.Foreground="{DynamicResource MaterialDesignBody}">
            <TextBlock
                Margin="0,0,0,8"
                FontSize="18"
                FontWeight="SemiBold"
                Foreground="{DynamicResource MaterialDesignBody}"
                Text="标签样式设置" />

            <!--  标签点样式  -->
            <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Opacity="0.8" Text="标签点样式" />
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <RadioButton GroupName="DotStyle" IsChecked="{Binding DotStyle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Circle, Mode=TwoWay}" Tag="Circle" />
                <RadioButton GroupName="DotStyle" IsChecked="{Binding DotStyle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Square, Mode=TwoWay}" Tag="Square" />
                <RadioButton GroupName="DotStyle" IsChecked="{Binding DotStyle, Converter={StaticResource EnumToBoolConverter}, ConverterParameter=Transparent, Mode=TwoWay}" Tag="Select" />
            </StackPanel>

            <!--  文字背景颜色  -->
            <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Opacity="0.8" Text="背景颜色" />
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <Button Background="White" Command="{Binding SetBackgroundColorCommand}" CommandParameter="White" Style="{StaticResource BackgroundColorPickerButtonStyle}" />
                <Button Background="Black" Command="{Binding SetBackgroundColorCommand}" CommandParameter="Black" Style="{StaticResource BackgroundColorPickerButtonStyle}" />
                <Button Background="RoyalBlue" Command="{Binding SetBackgroundColorCommand}" CommandParameter="RoyalBlue" Style="{StaticResource BackgroundColorPickerButtonStyle}" />
            </StackPanel>

            <!--  文字背景透明度  -->
            <TextBlock Margin="0,8,0,4" FontWeight="SemiBold" Opacity="0.8" Text="背景透明度" />
            <Slider
                Margin="0,0,0,8"
                IsSnapToTickEnabled="True"
                Maximum="1"
                Minimum="0"
                TickFrequency="0.1"
                Value="{Binding TextBackgroundOpacity, Mode=TwoWay}" />

            <!--  文字前景颜色  -->
            <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Opacity="0.8" Text="文字颜色" />
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <Button Background="White" Command="{Binding SetForegroundColorCommand}" CommandParameter="White" Style="{StaticResource ForegroundColorPickerButtonStyle}" />
                <Button Background="Black" Command="{Binding SetForegroundColorCommand}" CommandParameter="Black" Style="{StaticResource ForegroundColorPickerButtonStyle}" />
                <Button Background="RoyalBlue" Command="{Binding SetForegroundColorCommand}" CommandParameter="RoyalBlue" Style="{StaticResource ForegroundColorPickerButtonStyle}" />
            </StackPanel>

            <!--  标签缩放  -->
            <TextBlock Margin="0,0,0,8" FontWeight="SemiBold" Opacity="0.8" Text="标签缩放" />
            <StackPanel Margin="0,0,0,8" Orientation="Horizontal">
                <Button Command="{Binding ZoomInLabelCommand}" Tag="Plus" ToolTip="放大标签" />
                <Button Command="{Binding ZoomOutLabelCommand}" Tag="Minus" ToolTip="缩小标签" />
            </StackPanel>

            <Button
                Margin="0,0,0,8"
                Background="RoyalBlue"
                Command="{Binding ResetToDefaultsCommand}"
                Content="恢复默认样式"
                FontWeight="Bold"
                Tag="Restore" />
        </StackPanel>
    </Border>
</UserControl>
