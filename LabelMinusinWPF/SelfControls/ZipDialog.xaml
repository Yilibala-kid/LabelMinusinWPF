<Window
    x:Class="LabelMinusinWPF.ZipDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sc="clr-namespace:LabelMinusinWPF.SelfControls"
    Width="400"
    Height="400"
    Background="{DynamicResource MaterialDesignPaper}"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SelfControls/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ZipListItemStyle" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border
                                x:Name="ItemBorder"
                                Margin="0,0,0,6"
                                Padding="12,10"
                                Background="{DynamicResource MaterialDesignPaper}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Cursor="Hand">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="RoyalBlue" />
                                </Trigger>
                                <Trigger Property="IsSelected" Value="True">
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="RoyalBlue" />
                                    <Setter TargetName="ItemBorder" Property="Background" Value="#144169E1" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ZipOptionNameStyle" TargetType="TextBlock">
                <Setter Property="FontWeight" Value="SemiBold" />
            </Style>

            <Style x:Key="ZipOptionDescriptionStyle" TargetType="TextBlock">
                <Setter Property="Margin" Value="0,2,0,0" />
                <Setter Property="Opacity" Value="0.62" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <sc:DialogHeaderPresenter
            Grid.Row="0"
            Description="关联后，恢复时会优先加载该压缩包中的图片"
            Header="关联压缩包"
            Icon="FolderZip" />

        <Grid Grid.Row="1" Margin="4">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="1" Style="{StaticResource DialogContentBorderStyle}">
                <ListBox
                    x:Name="ZipListBox"
                    Padding="8"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource ZipListItemStyle}"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectionMode="Single">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <materialDesign:PackIcon
                                    Width="22"
                                    Height="22"
                                    Margin="0,0,10,0"
                                    Kind="{Binding Icon}" />
                                <StackPanel Orientation="Vertical">
                                    <TextBlock Style="{StaticResource ZipOptionNameStyle}" Text="{Binding Name}" />
                                    <TextBlock Style="{StaticResource ZipOptionDescriptionStyle}" Text="{Binding Description}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource DialogFooterBorderStyle}">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button Style="{StaticResource DialogButtonBaseStyle}" Margin="0,0,8,0" Click="Cancel_Click" Content="取消" IsCancel="True" Tag="close" />
                <Button Style="{StaticResource DialogButtonBaseStyle}" Click="OK_Click" Content="确定" IsDefault="True" Tag="check" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
