<UserControl
    x:Class="LabelMinusinWPF.SelfControls.LabelEditPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:common="clr-namespace:LabelMinusinWPF.Common"
    xmlns:sc="clr-namespace:LabelMinusinWPF.SelfControls"
    mc:Ignorable="d">
    <UserControl.Resources>
        <common:IsNullOrEmptyConverter x:Key="IsNullOrEmptyConverter" />
        <common:IsNewLabelConverter x:Key="IsNewLabelConverter" />
        <common:IsModifiedLabelConverter x:Key="IsModifiedLabelConverter" />
        <common:SelectedLabelIndexConverter x:Key="SelectedLabelIndexConverter" />
        <common:LabelEditPanelIndexConverter x:Key="LabelEditPanelIndexConverter" />

        <SolidColorBrush x:Key="ReviewNewBrush" Color="#404CAF50" />
        <SolidColorBrush x:Key="ReviewDeletedBrush" Color="#40F44336" />
        <SolidColorBrush x:Key="ReviewModifiedBrush" Color="#40FFC107" />

        <Style x:Key="LabelRowStyle" TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="FontWeight" Value="Bold" />
                </Trigger>
                <MultiDataTrigger>
                    <MultiDataTrigger.Conditions>
                        <Condition Binding="{Binding Tag, RelativeSource={RelativeSource AncestorType=DataGrid}}" Value="True" />
                        <Condition Binding="{Binding IsDeleted}" Value="True" />
                    </MultiDataTrigger.Conditions>
                    <Setter Property="Background" Value="{DynamicResource ReviewDeletedBrush}" />
                </MultiDataTrigger>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource IsNewLabelConverter}">
                            <Binding Path="Tag" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                            <Binding Path="IsDeleted" />
                            <Binding Path="OriginalText" />
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{DynamicResource ReviewNewBrush}" />
                </DataTrigger>
                <DataTrigger Value="True">
                    <DataTrigger.Binding>
                        <MultiBinding Converter="{StaticResource IsModifiedLabelConverter}">
                            <Binding Path="Tag" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                            <Binding Path="IsDeleted" />
                            <Binding Path="Text" />
                            <Binding Path="OriginalText" />
                        </MultiBinding>
                    </DataTrigger.Binding>
                    <Setter Property="Background" Value="{DynamicResource ReviewModifiedBrush}" />
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LabelDataGridStyle" TargetType="DataGrid" BasedOn="{StaticResource MaterialDesignDataGrid}">
            <Setter Property="Margin" Value="0,0,5,0" />
            <Setter Property="AutoGenerateColumns" Value="False" />
            <Setter Property="BorderBrush" Value="RoyalBlue" />
            <Setter Property="BorderThickness" Value="2" />
            <Setter Property="CanUserAddRows" Value="False" />
            <Setter Property="CanUserDeleteRows" Value="False" />
            <Setter Property="GridLinesVisibility" Value="Horizontal" />
            <Setter Property="HeadersVisibility" Value="None" />
            <Setter Property="SelectionMode" Value="Single" />
            <Setter Property="AlternationCount" Value="2" />
            <Setter Property="AlternatingRowBackground" Value="{DynamicResource MaterialDesignDataGridRowHoverBackground}" />
            <Setter Property="RowStyle" Value="{StaticResource LabelRowStyle}" />
        </Style>

        <Style x:Key="CenteredCellStyle" TargetType="TextBlock">
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>

        <Style x:Key="WrapCellStyle" TargetType="TextBlock">
            <Setter Property="TextWrapping" Value="Wrap" />
        </Style>
    </UserControl.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="35" />
            <RowDefinition x:Name="ListRow" Height="4*" />
            <RowDefinition x:Name="SplitterRow" Height="10" />
            <RowDefinition x:Name="TextRow" Height="1*" />
        </Grid.RowDefinitions>

        <!-- 组别栏 -->
        <sc:GroupPanel Grid.Row="0" VerticalAlignment="Center" />

        <!-- 列表 -->
        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="1*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <DataGrid
                x:Name="MainDataGrid"
                Grid.Row="0"
                Style="{StaticResource LabelDataGridStyle}"
                SelectedItem="{Binding SelectedImage.SelectedLabel, Mode=TwoWay}"
                Tag="{Binding IsReviewMode, RelativeSource={RelativeSource AncestorType=UserControl}}">
                <DataGrid.Columns>
                    <DataGridTextColumn ElementStyle="{StaticResource CenteredCellStyle}" Header="序号" IsReadOnly="True">
                        <DataGridTextColumn.Binding>
                            <MultiBinding Converter="{StaticResource LabelEditPanelIndexConverter}">
                                <Binding />
                                <Binding Path="IsDeleted" />
                                <Binding Path="DataContext.SelectedImage.ActiveLabels" RelativeSource="{RelativeSource AncestorType=DataGrid}" />
                            </MultiBinding>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    <DataGridTemplateColumn Width="*" Header="内容" >
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Text}" TextWrapping="Wrap" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>

                        <DataGridTemplateColumn.CellEditingTemplate>
                            <DataTemplate>
                                <TextBox
                                    AcceptsReturn="True"
                                    Background="White"
                                    BorderThickness="0"
                                    Foreground="Black"
                                    Style="{x:Null}"
                                    Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                    TextWrapping="Wrap" />
                            </DataTemplate>
                        </DataGridTemplateColumn.CellEditingTemplate>
                    </DataGridTemplateColumn>
                    <DataGridTextColumn x:Name="OriginalTextColumn" Binding="{Binding OriginalText}" Header="原文" IsReadOnly="True" Width="*" Foreground="Gray"
                        ElementStyle="{StaticResource WrapCellStyle}" Visibility="Collapsed" />

                    <DataGridTextColumn MinWidth="60" Binding="{Binding Group}" ElementStyle="{StaticResource CenteredCellStyle}" Header="组" IsReadOnly="True" />
                </DataGrid.Columns>
            </DataGrid>

            <!-- 文校模式原文 -->
            <Grid Grid.Row="1" x:Name="ReviewBottomPanel" Margin="0,0,5,5" Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>
                <TextBlock Grid.Row="0" FontWeight="Bold" Text="原文" Margin="0,0,0,2" Foreground="{DynamicResource MaterialDesignBodyLight}" />
                <Border
                    Grid.Row="1"
                    BorderThickness="1"
                    BorderBrush="{DynamicResource MaterialDesignBodyLight}"
                    CornerRadius="4"
                    Padding="8">
                    <TextBlock
                        FontSize="14"
                        Foreground="{DynamicResource MaterialDesignBodyLight}"
                        Text="{Binding SelectedImage.SelectedLabel.OriginalText}"
                        TextWrapping="Wrap" />
                </Border>
            </Grid>
        </Grid>

        <GridSplitter Grid.Row="2" HorizontalAlignment="Stretch" Background="Transparent" ResizeBehavior="PreviousAndNext" />

        <!-- 文本框 -->
        <TextBox
            x:Name="LabelTextBox"
            Grid.Row="3"
            Margin="0,0,5,5"
            materialDesign:HintAssist.FontFamily="微软雅黑"
            materialDesign:HintAssist.Hint="{Binding SelectedImage.SelectedLabel, Converter={StaticResource SelectedLabelIndexConverter}}"
            AcceptsReturn="True"
            FontSize="16"
            IsEnabled="{Binding SelectedImage.SelectedLabel, Converter={StaticResource IsNullOrEmptyConverter}, ConverterParameter=Disable}"
            Style="{StaticResource MaterialDesignOutlinedTextBox}"
            Foreground="{DynamicResource MaterialDesignBody}"
            Text="{Binding SelectedImage.SelectedLabel.Text, UpdateSourceTrigger=PropertyChanged}"
            TextAlignment="Left"
            TextWrapping="Wrap"
            VerticalScrollBarVisibility="Auto" />
    </Grid>
</UserControl>
