<Window x:Class="LabelMinusinWPF.OcrRecognitionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        Title="OCR识别" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource MaterialDesignPaper}">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="1*" />
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="2*" />
        </Grid.ColumnDefinitions>

        <!-- 左侧：截图显示 -->
        <Border Grid.Column="0" BorderBrush="{DynamicResource MaterialDesignDivider}" BorderThickness="0,0,1,0">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="截图预览" Margin="16,16,16,8"
                           Style="{StaticResource MaterialDesignHeadline6TextBlock}" />

                <Border Grid.Row="1" Margin="16" BorderBrush="{DynamicResource MaterialDesignDivider}"
                        BorderThickness="1" Background="{DynamicResource MaterialDesignCardBackground}">
                    <Viewbox Stretch="Uniform">
                        <Image x:Name="ScreenshotImage" />
                    </Viewbox>
                </Border>
            </Grid>
        </Border>

        <!-- 分割线 -->
        <GridSplitter Grid.Column="1" Width="5" Background="RoyalBlue"
                      HorizontalAlignment="Center" VerticalAlignment="Stretch" />

        <!-- 右侧：WebView2浏览器 -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock x:Name="WebsiteTitle" Grid.Row="0" Text="识别网站" Margin="16,16,16,8"
                       Style="{StaticResource MaterialDesignHeadline6TextBlock}" />

            <wv2:WebView2 x:Name="WebBrowser" Grid.Row="1" Margin="16,0,16,16" />
        </Grid>
    </Grid>
</Window>
