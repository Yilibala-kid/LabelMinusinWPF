<Window
    x:Class="LabelMinusinWPF.ImageSelectDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sc="clr-namespace:LabelMinusinWPF.SelfControls"
    Width="740"
    Height="620"
    MinWidth="620"
    MinHeight="500"
    Background="{DynamicResource MaterialDesignPaper}"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SelfControls/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="ImageListItemStyle" TargetType="ListBoxItem">
                <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="ListBoxItem">
                            <Border
                                x:Name="ItemBorder"
                                Margin="4"
                                Padding="10,8"
                                Background="{DynamicResource MaterialDesignPaper}"
                                BorderBrush="{DynamicResource MaterialDesignDivider}"
                                BorderThickness="1"
                                CornerRadius="6"
                                Cursor="Hand">
                                <ContentPresenter />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="ItemBorder" Property="BorderBrush" Value="RoyalBlue" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="ImageSelectionCheckBoxStyle" TargetType="CheckBox">
                <Setter Property="MinWidth" Value="100" />
                <Setter Property="VerticalAlignment" Value="Center" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="IsHitTestVisible" Value="False" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <sc:DialogHeaderPresenter x:Name="DialogHeader" Grid.Row="0" Icon="ImageMultiple" />

        <Grid Grid.Row="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <Border Grid.Row="1" Style="{StaticResource DialogContentBorderStyle}">
                <ListBox
                    x:Name="ImageListBox"
                    Padding="8"
                    BorderThickness="0"
                    ItemContainerStyle="{StaticResource ImageListItemStyle}"
                    ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                    ScrollViewer.VerticalScrollBarVisibility="Auto"
                    SelectionMode="Multiple"
                    VirtualizingStackPanel.IsVirtualizing="True"
                    VirtualizingStackPanel.VirtualizationMode="Recycling">
                    <ListBox.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" />
                        </ItemsPanelTemplate>
                    </ListBox.ItemsPanel>
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <CheckBox
                                Style="{StaticResource ImageSelectionCheckBoxStyle}"
                                Content="{Binding ImageName}"
                                Foreground="{DynamicResource MaterialDesignBody}"
                                IsChecked="{Binding IsSelected, Mode=TwoWay}" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Border>
        </Grid>

        <Border Grid.Row="2" Style="{StaticResource DialogFooterBorderStyle}">
            <Grid>
                <StackPanel HorizontalAlignment="Left" Orientation="Horizontal">
                    <Button Style="{StaticResource DialogButtonBaseStyle}" Margin="0,0,8,0" Click="SelectAll_Click" Content="全选" Tag="SelectAll" />
                    <Button Style="{StaticResource DialogButtonBaseStyle}" Click="DeselectAll_Click" Content="全不选" Tag="SelectOff" />
                </StackPanel>

                <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                    <Button Style="{StaticResource DialogButtonBaseStyle}" Margin="0,0,8,0" Click="Cancel_Click" Content="取消" IsCancel="True" Tag="close" />
                    <Button Style="{StaticResource DialogButtonBaseStyle}" Click="OK_Click" Content="确定" IsDefault="True" Tag="check" />
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
