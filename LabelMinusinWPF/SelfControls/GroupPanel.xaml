<UserControl
    x:Class="LabelMinusinWPF.SelfControls.GroupPanel"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">
    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
        <ListBox ItemContainerStyle="{StaticResource GroupBadgeItemStyle}" ItemsSource="{Binding AllGroups}" SelectedValue="{Binding SelectedGroup, Mode=TwoWay}">
            <ListBox.ItemsPanel>
                <ItemsPanelTemplate>
                    <StackPanel Orientation="Horizontal" />
                </ItemsPanelTemplate>
            </ListBox.ItemsPanel>
        </ListBox>
        <StackPanel x:Name="AddGroupPanel" Orientation="Horizontal" Visibility="Collapsed">
            <TextBox x:Name="NewGroupTextBox" Width="80" Margin="5,0,0,0" KeyDown="NewGroupTextBox_KeyDown" />
            <Button Tag="Check" Click="ConfirmAdd_Click" ToolTip="确认添加" />
            <Button Tag="Close" Click="CancelAdd_Click" ToolTip="取消添加" />
        </StackPanel>
        <StackPanel x:Name="IdleButtonPanel" Orientation="Horizontal">
            <Button Tag="Plus" Click="AddGroup_Click" ToolTip="添加组别" />
            <Button Tag="Minus" Click="DeleteGroup_Click" ToolTip="删除选中组别" />
        </StackPanel>
    </StackPanel>
</UserControl>
