<Window
    x:Class="LabelMinusinWPF.SettingsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
    xmlns:sc="clr-namespace:LabelMinusinWPF.SelfControls"
    Width="300"
    Height="600"
    MinWidth="300"
    MinHeight="390"
    Background="{DynamicResource MaterialDesignPaper}"
    TextElement.Foreground="{DynamicResource MaterialDesignBody}"
    WindowStartupLocation="CenterOwner">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/SelfControls/DialogStyles.xaml" />
            </ResourceDictionary.MergedDictionaries>

            <Style x:Key="SettingTextColumnStyle" TargetType="StackPanel">
                <Setter Property="Margin" Value="0,0,24,0" />
            </Style>

            <Style x:Key="SettingsToggleStyle" TargetType="CheckBox">
                <Setter Property="VerticalAlignment" Value="Center" />
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <sc:DialogHeaderPresenter Grid.Row="0" Description="修改后点击确定统一保存" Header="设置" Icon="CogOutline" />

        <ScrollViewer Grid.Row="1" Margin="16" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Style="{StaticResource SettingTextColumnStyle}">
                        <TextBlock Style="{StaticResource DialogSettingTitleStyle}" Text="启动后进入图校" />
                        <TextBlock Style="{StaticResource DialogSettingHintStyle}" Text="启动时直接打开图校页面" />
                    </StackPanel>

                    <CheckBox x:Name="OpenImageReviewOnStartupCheckBox" Grid.Column="1" Style="{StaticResource SettingsToggleStyle}" />
                </Grid>

                <Grid Margin="0,0,0,4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Style="{StaticResource SettingTextColumnStyle}">
                        <TextBlock Style="{StaticResource DialogSettingTitleStyle}" Text="自动加载上一次项目" />
                        <TextBlock Style="{StaticResource DialogSettingHintStyle}" Text="恢复关闭时仍打开的 .txt 翻译，仅预览内容不会恢复" />
                    </StackPanel>

                    <CheckBox x:Name="AutoLoadLastProjectCheckBox" Grid.Column="1" Style="{StaticResource SettingsToggleStyle}" />
                </Grid>

                <Border Margin="0,0,0,8" Style="{StaticResource DialogDividerStyle}" />

                <Grid Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Style="{StaticResource SettingTextColumnStyle}">
                        <TextBlock Style="{StaticResource DialogSettingTitleStyle}" Text="自动保存间隔" />
                        <TextBlock Style="{StaticResource DialogSettingHintStyle}" Text="可选 1 到 60 分钟" />
                    </StackPanel>

                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal">
                        <TextBox
                            x:Name="AutoSaveIntervalTextBox"
                            Width="64"
                            Margin="0,0,8,0"
                            HorizontalContentAlignment="Center"
                            KeyDown="AutoSaveIntervalTextBox_KeyDown"
                            LostFocus="AutoSaveIntervalTextBox_LostFocus" />
                        <TextBlock VerticalAlignment="Center" Text="分钟" />
                    </StackPanel>
                </Grid>

                <Button
                    Margin="0,0,0,4"
                    HorizontalAlignment="Left"
                    Click="OpenAutoSaveFolder_Click"
                    Content="打开自动保存文件夹"
                    Style="{StaticResource DialogButtonBaseStyle}"
                    Tag="FolderOpenOutline" />

                <Border Margin="0,0,0,8" Style="{StaticResource DialogDividerStyle}" />

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Style="{StaticResource SettingTextColumnStyle}">
                        <TextBlock Style="{StaticResource DialogSettingTitleStyle}" Text="右键打开" />
                        <TextBlock Style="{StaticResource DialogSettingHintStyle}" Text="加入文件和文件夹的右键菜单" />
                    </StackPanel>

                    <CheckBox x:Name="RightClickOpenCheckBox" Grid.Column="1" Style="{StaticResource SettingsToggleStyle}" />
                </Grid>
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Padding="24,8" Style="{StaticResource DialogFooterBorderStyle}">
            <StackPanel HorizontalAlignment="Right" Orientation="Horizontal">
                <Button
                    Margin="0,0,8,0"
                    Click="Cancel_Click"
                    Content="取消"
                    IsCancel="True"
                    Style="{StaticResource DialogButtonBaseStyle}"
                    Tag="close" />
                <Button
                    Click="Ok_Click"
                    Content="确定"
                    IsDefault="True"
                    Style="{StaticResource DialogButtonBaseStyle}"
                    Tag="check" />
            </StackPanel>
        </Border>
    </Grid>
</Window>
