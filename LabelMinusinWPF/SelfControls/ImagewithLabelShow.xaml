<UserControl
    x:Class="LabelMinusinWPF.ImagewithLabelShow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:LabelMinusinWPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <local:ImageRelativePositionConverter x:Key="PosConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:AllBoolToVisibilityConverter x:Key="AllBoolToVis" />
    </UserControl.Resources>

    <Grid
        x:Name="ViewportGrid"
        Background="Transparent"
        ClipToBounds="True"
        MouseLeftButtonDown="Viewport_MouseLeftDown"
        MouseLeftButtonUp="Viewport_MouseLeftUp"
        MouseMove="Viewport_MouseMove"
        MouseWheel="Viewport_MouseWheel">

        <Grid x:Name="ContentGrid" Background="Transparent">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="{Binding ZoomScale, RelativeSource={RelativeSource AncestorType=local:ImagewithLabelShow}}" ScaleY="{Binding ZoomScale, RelativeSource={RelativeSource AncestorType=local:ImagewithLabelShow}}" />
                    <TranslateTransform X="{Binding OffsetX, RelativeSource={RelativeSource AncestorType=local:ImagewithLabelShow}}" Y="{Binding OffsetY, RelativeSource={RelativeSource AncestorType=local:ImagewithLabelShow}}" />
                </TransformGroup>
            </Grid.RenderTransform>
            <!-- 图片 -->
            <Image x:Name="TargetImage" Source="{Binding ImageSource}" />

            <!-- 标记层 -->
            <ItemsControl
                x:Name="LabelItemsControl"
                Width="{Binding ActualWidth, ElementName=TargetImage}"
                Height="{Binding ActualHeight, ElementName=TargetImage}"
                ItemsSource="{Binding ActiveLabels}"
                MouseMove="LabelItemsControl_MouseMove"
                MouseLeftButtonUp="LabelItemsControl_MouseLeftUp">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="Transparent" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- 定位 -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="X">
                                    <Binding Path="X" />
                                    <Binding ElementName="TargetImage" />
                                    <Binding ElementName="TargetImage" Path="ActualWidth" />
                                    <Binding ElementName="TargetImage" Path="ActualHeight" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Canvas.Top">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="Y">
                                    <Binding Path="Y" />
                                    <Binding ElementName="TargetImage" />
                                    <Binding ElementName="TargetImage" Path="ActualWidth" />
                                    <Binding ElementName="TargetImage" Path="ActualHeight" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Margin" Value="-9,-9,0,0" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <!-- 标记内容 -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Orientation="Horizontal">
                            <!-- 未选中时半透明 -->
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Opacity" Value="0.8" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="Opacity" Value="1.0" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <!-- 点：颜色跟随组别，悬停显示拖动光标 -->
                            <Border Cursor="Hand" Style="{Binding LabelDotStyle, RelativeSource={RelativeSource AncestorType=local:ImagewithLabelShow}, TargetNullValue={StaticResource DefaultDotStyle}}" MouseLeftButtonDown="LabelNode_LeftMouseDown" MouseRightButtonDown="LabelNode_RightMouseDown" Visibility="{Binding IsIndexVisible, RelativeSource={RelativeSource AncestorType=local:ImagewithLabelShow}, Converter={StaticResource BoolToVis}}">
                                <TextBlock Text="{Binding Index}" />
                            </Border>
                            <!-- 文字：仅选中时显示 -->
                            <Border Style="{Binding LabelTextStyle, RelativeSource={RelativeSource AncestorType=local:ImagewithLabelShow}, TargetNullValue={StaticResource DefaultTextStyle}}" MouseLeftButtonDown="LabelText_MouseLeftDown">
                                <Border.Visibility>
                                    <MultiBinding Converter="{StaticResource AllBoolToVis}">
                                        <Binding Path="IsSelected" />
                                        <Binding Path="IsTextVisible" RelativeSource="{RelativeSource AncestorType=local:ImagewithLabelShow}" />
                                    </MultiBinding>
                                </Border.Visibility>

                                <TextBlock Text="{Binding Text}" />
                            </Border>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </Grid>
        <Canvas
            x:Name="SnipCanvas"
            Background="Transparent"
            Visibility="Collapsed"
            MouseLeftButtonDown="SnipCanvas_MouseLeftButtonDown"
            MouseMove="SnipCanvas_MouseMove"
            MouseLeftButtonUp="SnipCanvas_MouseLeftButtonUp">
            <Rectangle
                x:Name="SnipRectangle"
                Stroke="DodgerBlue"
                StrokeThickness="2"
                StrokeDashArray="4 4"
                Fill="#200078D7"
                Visibility="Collapsed" />
        </Canvas>

    </Grid>
</UserControl>
