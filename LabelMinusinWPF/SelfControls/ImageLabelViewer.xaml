<UserControl
    x:Class="LabelMinusinWPF.ImageLabelViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:LabelMinusinWPF"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sc="clr-namespace:LabelMinusinWPF.SelfControls"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <local:ImageRelativePositionConverter x:Key="PosConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <local:AllBoolToVisibilityConverter x:Key="AllBoolToVis" />
    </UserControl.Resources>

    <Grid
        x:Name="ViewportGrid"
        Background="Transparent"
        ClipToBounds="True"
        MouseLeftButtonDown="OnViewportDown"
        MouseLeftButtonUp="OnViewportUp"
        MouseMove="OnViewportMove"
        MouseWheel="OnViewportWheel">

        <Grid x:Name="ContentGrid" Background="Transparent">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="{Binding ZoomScale, RelativeSource={RelativeSource AncestorType=local:ImageLabelViewer}}" ScaleY="{Binding ZoomScale, RelativeSource={RelativeSource AncestorType=local:ImageLabelViewer}}" />
                    <TranslateTransform X="{Binding OffsetX, RelativeSource={RelativeSource AncestorType=local:ImageLabelViewer}}" Y="{Binding OffsetY, RelativeSource={RelativeSource AncestorType=local:ImageLabelViewer}}" />
                </TransformGroup>
            </Grid.RenderTransform>
            <!--  图片  -->
            <Image x:Name="TargetImage" Source="{Binding DisplayImage}" />

            <!--  标记层  -->
            <ItemsControl
                x:Name="LabelItemsControl"
                Width="{Binding ActualWidth, ElementName=TargetImage}"
                Height="{Binding ActualHeight, ElementName=TargetImage}"
                ItemsSource="{Binding ActiveLabels}"
                MouseLeftButtonUp="OnLabelContainerUp"
                MouseMove="OnLabelContainerMove">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="Transparent" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!--  定位  -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="X">
                                    <Binding Path="X" />
                                    <Binding ElementName="TargetImage" />
                                    <Binding ElementName="TargetImage" Path="ActualWidth" />
                                    <Binding ElementName="TargetImage" Path="ActualHeight" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Canvas.Top">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="Y">
                                    <Binding Path="Y" />
                                    <Binding ElementName="TargetImage" />
                                    <Binding ElementName="TargetImage" Path="ActualWidth" />
                                    <Binding ElementName="TargetImage" Path="ActualHeight" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Margin" Value="-9,-9,0,0" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <!--  标记内容  -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!--  外层 StackPanel 用于整体缩放  -->
                        <StackPanel Orientation="Horizontal" RenderTransformOrigin="0,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="{Binding LabelScale, RelativeSource={RelativeSource AncestorType=local:ImageLabelViewer}}" ScaleY="{Binding LabelScale, RelativeSource={RelativeSource AncestorType=local:ImageLabelViewer}}" />
                            </StackPanel.RenderTransform>
                            <StackPanel Orientation="Horizontal">
                                <!--  未选中时半透明  -->
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Opacity" Value="0.8" />
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Opacity" Value="1.0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <!--  点：颜色跟随组别，悬停显示拖动光标  -->
                                <Border
                                    Cursor="Hand"
                                    MouseLeftButtonDown="LabelNode_LeftMouseDown"
                                    MouseRightButtonDown="LabelNode_RightMouseDown"
                                    Style="{Binding Source={x:Static sc:LabelStyleManager.Instance}, Path=LabelDotStyle, TargetNullValue={StaticResource DefaultDotStyle}}"
                                    Visibility="{Binding IsIndexVisible, RelativeSource={RelativeSource AncestorType=local:ImageLabelViewer}, Converter={StaticResource BoolToVis}}">
                                    <TextBlock Text="{Binding Index}" />
                                </Border>
                                <!--  文字：仅选中时显示  -->
                                <Border MouseLeftButtonDown="LabelText_MouseLeftDown" Style="{Binding LabelTextStyle, RelativeSource={RelativeSource AncestorType=local:ImageLabelViewer}, TargetNullValue={StaticResource DefaultTextStyle}}">
                                    <Border.Background>
                                        <SolidColorBrush Opacity="{Binding Source={x:Static sc:LabelStyleManager.Instance}, Path=TextBackgroundOpacity}" Color="{Binding Source={x:Static sc:LabelStyleManager.Instance}, Path=TextBackgroundColor}" />
                                    </Border.Background>
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource AllBoolToVis}">
                                            <Binding Path="IsSelected" />
                                            <Binding Path="IsTextVisible" RelativeSource="{RelativeSource AncestorType=local:ImageLabelViewer}" />
                                        </MultiBinding>
                                    </Border.Visibility>

                                    <TextBlock Text="{Binding Text}">
                                        <TextBlock.Foreground>
                                            <SolidColorBrush Color="{Binding Source={x:Static sc:LabelStyleManager.Instance}, Path=TextForegroundColor}" />
                                        </TextBlock.Foreground>
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </Grid>
        <Canvas
            x:Name="SnipCanvas"
            Background="Transparent"
            MouseLeftButtonDown="SnipCanvas_MouseLeftButtonDown"
            MouseLeftButtonUp="SnipCanvas_MouseLeftButtonUp"
            MouseMove="SnipCanvas_MouseMove"
            Visibility="Collapsed">
            <Rectangle
                x:Name="SnipRectangle"
                Fill="#200078D7"
                Stroke="DodgerBlue"
                StrokeDashArray="4 4"
                StrokeThickness="2"
                Visibility="Collapsed" />
        </Canvas>

    </Grid>
</UserControl>
