<UserControl
    x:Class="LabelMinusinWPF.ImageLabelViewer"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:i="http://schemas.microsoft.com/xaml/behaviors"
    xmlns:local="clr-namespace:LabelMinusinWPF"
    xmlns:common="clr-namespace:LabelMinusinWPF.Common"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:sc="clr-namespace:LabelMinusinWPF.SelfControls"
    x:Name="self"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <UserControl.Resources>
        <common:ImageRelativePositionConverter x:Key="PosConverter" />
        <BooleanToVisibilityConverter x:Key="BoolToVis" />
        <common:LabelTextVisibilityConverter x:Key="LabelTextVisibilityConverter" />
        <common:LabelReferenceVisibilityConverter x:Key="LabelReferenceVisibilityConverter" />
    </UserControl.Resources>

    <Grid
        x:Name="ViewportGrid"
        Background="Transparent"
        ClipToBounds="True"
        MouseLeftButtonDown="OnViewportDown"
        MouseLeftButtonUp="OnViewportUp"
        MouseMove="OnViewportMove"
        MouseWheel="OnViewportWheel">

        <Grid x:Name="ContentGrid" Background="Transparent">
            <Grid.RenderTransform>
                <TransformGroup>
                    <ScaleTransform ScaleX="{Binding ZoomScale, ElementName=self}" ScaleY="{Binding ZoomScale, ElementName=self}" />
                    <TranslateTransform X="{Binding OffsetX, ElementName=self}" Y="{Binding OffsetY, ElementName=self}" />
                </TransformGroup>
            </Grid.RenderTransform>
            <!-- 图片 -->
            <Image x:Name="TargetImage" Source="{Binding DisplayImage}" />

            <!-- 标记层 -->
            <ItemsControl
                x:Name="LabelItemsControl"
                Width="{Binding ActualWidth, ElementName=TargetImage}"
                Height="{Binding ActualHeight, ElementName=TargetImage}"
                ItemsSource="{Binding ActiveLabels}"
                AlternationCount="1000"
                MouseLeftButtonUp="OnLabelContainerUp"
                MouseMove="OnLabelContainerMove"
                Visibility="{Binding CanLabel, ElementName=self, Converter={StaticResource BoolToVis}}">

                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <Canvas Background="Transparent" />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>

                <!-- 定位 -->
                <ItemsControl.ItemContainerStyle>
                    <Style TargetType="ContentPresenter">
                        <Setter Property="Canvas.Left">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="X">
                                    <Binding Path="X" />
                                    <Binding ElementName="TargetImage" />
                                    <Binding ElementName="TargetImage" Path="ActualWidth" />
                                    <Binding ElementName="TargetImage" Path="ActualHeight" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Canvas.Top">
                            <Setter.Value>
                                <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="Y">
                                    <Binding Path="Y" />
                                    <Binding ElementName="TargetImage" />
                                    <Binding ElementName="TargetImage" Path="ActualWidth" />
                                    <Binding ElementName="TargetImage" Path="ActualHeight" />
                                </MultiBinding>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Margin" Value="-9,-9,0,0" />
                    </Style>
                </ItemsControl.ItemContainerStyle>

                <!-- 标记内容 -->
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- 外层 StackPanel 用于整体缩放 -->
                        <StackPanel Orientation="Horizontal" RenderTransformOrigin="0,0.5">
                            <StackPanel.RenderTransform>
                                <ScaleTransform ScaleX="{Binding Source={x:Static sc:LabelStylePanel.Instance}, Path=LabelScale}" ScaleY="{Binding Source={x:Static sc:LabelStylePanel.Instance}, Path=LabelScale}" />
                            </StackPanel.RenderTransform>
                            <StackPanel x:Name="LabelStackPanel" Orientation="Horizontal" Background="Transparent">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Opacity" Value="0.8" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Opacity" Value="1.0" />
                                            </Trigger>
                                            <DataTrigger Value="Visible">
                                                <DataTrigger.Binding>
                                                    <MultiBinding Converter="{StaticResource LabelReferenceVisibilityConverter}">
                                                        <Binding />
                                                        <Binding ElementName="self" Path="DataContext.SelectedLabel" />
                                                    </MultiBinding>
                                                </DataTrigger.Binding>
                                                <Setter Property="Opacity" Value="1.0" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <!-- 点：颜色跟随组别 -->
                                <Border Cursor="Hand" MouseLeftButtonDown="LabelNode_LeftMouseDown" MouseRightButtonDown="LabelNode_RightMouseDown" Style="{Binding Source={x:Static sc:LabelStylePanel.Instance}, Path=LabelDotStyle, TargetNullValue={StaticResource DefaultDotStyle}}">
                                    <TextBlock Text="{Binding (ItemsControl.AlternationIndex), RelativeSource={RelativeSource AncestorType=ContentPresenter}, Converter={StaticResource IndexPlusOneConverter}}" />
                                </Border>
                                <!-- 文字：悬停或选中时显示 -->
                                <Border Style="{StaticResource DefaultTextStyle}" MouseLeftButtonDown="LabelText_MouseLeftButtonDown">
                                    <Border.Visibility>
                                        <MultiBinding Converter="{StaticResource LabelTextVisibilityConverter}">
                                            <Binding Path="IsMouseOver" RelativeSource="{RelativeSource AncestorType=StackPanel}" />
                                            <Binding />
                                            <Binding ElementName="self" Path="DataContext.SelectedLabel" />
                                        </MultiBinding>
                                    </Border.Visibility>
                                    <Border.Background>
                                        <SolidColorBrush Opacity="{Binding Source={x:Static sc:LabelStylePanel.Instance}, Path=TextBackgroundOpacity}" Color="{Binding Source={x:Static sc:LabelStylePanel.Instance}, Path=TextBackgroundColor}" />
                                    </Border.Background>

                                    <Grid>
                                        <TextBlock Text="{Binding Text}" MinWidth="20">
                                            <TextBlock.Visibility>
                                                <MultiBinding Converter="{StaticResource LabelReferenceVisibilityConverter}" ConverterParameter="Inverse">
                                                    <Binding />
                                                    <Binding ElementName="self" Path="EditingLabel" />
                                                </MultiBinding>
                                            </TextBlock.Visibility>
                                            <TextBlock.Foreground>
                                                <SolidColorBrush Color="{Binding Source={x:Static sc:LabelStylePanel.Instance}, Path=TextForegroundColor}" />
                                            </TextBlock.Foreground>
                                        </TextBlock>

                                        <TextBox
                                            MinWidth="30"
                                            MaxWidth="200"
                                            AcceptsReturn="True"
                                            Background="White"
                                            BorderThickness="0"
                                            Foreground="Black"
                                            IsVisibleChanged="LabelTextEditBox_IsVisibleChanged"
                                            LostKeyboardFocus="LabelTextEditBox_LostKeyboardFocus"
                                            Padding="2"
                                            PreviewKeyDown="LabelTextEditBox_PreviewKeyDown"
                                            Style="{x:Null}"
                                            Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                            TextWrapping="Wrap">
                                            <TextBox.Visibility>
                                                <MultiBinding Converter="{StaticResource LabelReferenceVisibilityConverter}">
                                                    <Binding />
                                                    <Binding ElementName="self" Path="EditingLabel" />
                                                </MultiBinding>
                                            </TextBox.Visibility>
                                        </TextBox>
                                    </Grid>
                                </Border>
                            </StackPanel>
                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>

            </ItemsControl>
        </Grid>
        <!-- 截图层 -->
        <Canvas
            x:Name="SnipCanvas"
            Background="Transparent"
            Cursor="Cross"
            MouseLeftButtonDown="SnipCanvas_MouseLeftButtonDown"
            MouseLeftButtonUp="SnipCanvas_MouseLeftButtonUp"
            MouseMove="SnipCanvas_MouseMove"
            Visibility="{Binding IsScreenShotMode, ElementName=self, Converter={StaticResource BoolToVis}}">
            <Rectangle
                x:Name="SnipRectangle"
                Fill="#200078D7"
                Stroke="DodgerBlue"
                StrokeDashArray="4 4"
                StrokeThickness="2"
                Visibility="Collapsed" />
        </Canvas>

    </Grid>
</UserControl>
