<UserControl x:Class="LabelMinusinWPF.ImagewithLabelShow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LabelMinusinWPF"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800">
    <UserControl.Resources>
        <local:ImageRelativePositionConverter x:Key="PosConverter"/>
    </UserControl.Resources>

    <Grid Background="{DynamicResource MaterialDesignPaper}">
        <!-- 图片 -->
        <Image x:Name="TargetImage"
               Source="{Binding ImageSource}"
               Stretch="Uniform"/>

        <!-- 标记层 -->
        <ItemsControl x:Name="MarkerItemsControl"
                      ItemsSource="{Binding Labels}"
                      Width="{Binding ActualWidth, ElementName=TargetImage}"
                      Height="{Binding ActualHeight, ElementName=TargetImage}"
                      HorizontalAlignment="Center"
                      VerticalAlignment="Center">

            <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                    <Canvas Background="Transparent"/>
                </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>

            <!-- 定位 -->
            <ItemsControl.ItemContainerStyle>
                <Style TargetType="ContentPresenter">
                    <Setter Property="Canvas.Left">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="X">
                                <Binding Path="X"/>
                                <Binding ElementName="TargetImage"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Canvas.Top">
                        <Setter.Value>
                            <MultiBinding Converter="{StaticResource PosConverter}" ConverterParameter="Y">
                                <Binding Path="Y"/>
                                <Binding ElementName="TargetImage"/>
                            </MultiBinding>
                        </Setter.Value>
                    </Setter>
                    <Setter Property="Margin" Value="-10,-10,0,0"/>
                </Style>
            </ItemsControl.ItemContainerStyle>

            <!-- 标记内容 -->
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Background="Transparent">

                        <!-- 点 -->
                        <Border Width="20" Height="20" Background="Red" CornerRadius="10"
                            MouseLeftButtonDown="Label_MouseDown"
                            MouseMove="Label_MouseMove"
                            MouseLeftButtonUp="Label_MouseUp">
                            <TextBlock Text="{Binding Index}" Foreground="White" FontWeight="Bold" 
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <!-- 文字 -->
                        <Border Background="#80000000" CornerRadius="2" Margin="4,0,0,0" Padding="4,2">
                            <TextBlock Text="{Binding Text}" Foreground="White" FontSize="12"/>
                        </Border>
                    </StackPanel>
                </DataTemplate>
            </ItemsControl.ItemTemplate>

        </ItemsControl>
    </Grid>
</UserControl>
