<Window x:Class="LabelMinusinWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabelMinusinWPF"
        mc:Ignorable="d"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
        xmlns:viewmodels="clr-namespace:LabelMinusinWPF.ViewModels" 
        d:DataContext="{d:DesignInstance Type=viewmodels:MainViewModel}"
        Title="LabelMinus" Height="800" Width="1000"
        
        
        >
    <Grid x:Name="RootGrid">
        <DockPanel Grid.ColumnSpan="2">
            <Menu DockPanel.Dock="Top" 
                  materialDesign:MenuAssist.TopLevelMenuItemHeight="25"
                  FontSize="12">
                <!-- 1. 文件 -->
                <MenuItem Header="文件" >
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="File"/>
                    </MenuItem.Icon>

                    <!-- 新建 -->
                    <MenuItem Header="新建">
                        <MenuItem Header="新建翻译"
                                  InputGestureText="Ctrl+N" />
                        <MenuItem Header="新建压缩包翻译" />
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="FilePlus" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator />

                    <!-- 翻译相关 -->
                    <MenuItem Header="打开翻译" />
                    <MenuItem Header="保存翻译"/>
                    <MenuItem Header="翻译另存为..." />

                    <Separator />

                    <!-- 图片相关 -->
                    <MenuItem Header="打开图片/压缩包" />
                    <MenuItem Header="打开图片文件夹" />

                    <Separator />

                    <MenuItem Header="打开当前文件夹" />
                </MenuItem>

                <!-- 2. 修改 -->
                <MenuItem Header="修改">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Pencil"/>
                    </MenuItem.Icon>

                    <!-- 来自 WinForms 版本的具体业务功能 -->
                    <MenuItem Header="关联压缩包" />
                    <MenuItem Header="调整图集" />
                    <MenuItem Header="组别" />

                    <Separator />

                    <MenuItem Header="文本框字号" />
                    <MenuItem Header="OCR网站" />

                    <Separator />

                    <!-- 通用编辑功能 -->
                    <MenuItem Header="撤销" Command="Undo" />
                    <MenuItem Header="重做" Command="Redo" />
                </MenuItem>

                <!-- 3. 导出文本 -->
                <MenuItem Header="导出文本">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Export"/>
                    </MenuItem.Icon>

                    <!-- 来自 WinForms 版本的内容导出 -->
                    <MenuItem Header="导出原翻译" />
                    <MenuItem Header="导出现翻译" />
                    <MenuItem Header="导出修改文档" />

                    <Separator />

                    <!-- 来自 WPF 版本的格式导出 -->
                    <MenuItem Header="导出为TXT" />
                    <MenuItem Header="导出为Excel" />
                </MenuItem>

                <!-- 4. 显示 -->
                <MenuItem Header="显示">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Monitor"/>
                    </MenuItem.Icon>

                    <!-- 布局模式 (WinForms) -->
                    <MenuItem Header="列表与文本框" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="仅列表" IsCheckable="True" />
                    <MenuItem Header="仅文本框" IsCheckable="True" />

                    <Separator />

                    <!-- 视图选项 (WinForms) -->
                    <MenuItem Header="次要参数" IsCheckable="True" />
                    <MenuItem Header="列表序号" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="列表组别" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="图片组别" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="图片文本" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="流畅图片显示" IsCheckable="True" IsChecked="True" />

                    <Separator />

                    <!-- 缩放与全屏 (WPF) -->
                    <MenuItem Header="全屏"/>
                    <MenuItem Header="放大"/>
                    <MenuItem Header="缩小"/>
                </MenuItem>

                <!-- 5. 高级 -->
                <MenuItem Header="高级">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Cogs"/>
                    </MenuItem.Icon>
                    <MenuItem Header="设置" />
                    <MenuItem Header="插件管理" />
                </MenuItem>

                <!-- 6. 帮助 -->
                <MenuItem Header="帮助" >
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Help"/>
                    </MenuItem.Icon>
                    <MenuItem Header="官网" />
                    <MenuItem Header="关于" />
                </MenuItem>

            </Menu>
            <ToolBarTray DockPanel.Dock="Top" Height="35">
                <ToolBar Style="{StaticResource MaterialDesignToolBar}" ClipToBounds="False">

                    <Button ToolTip="标记模式" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="Draw" VerticalAlignment="Center" />
                            <TextBlock Text="标记模式" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button ToolTip="文校模式" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="FileEdit" VerticalAlignment="Center" />
                            <TextBlock Text="文校模式" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Button ToolTip="识别模式" Padding="4">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="EyeCheck" VerticalAlignment="Center" />
                            <TextBlock Text="识别模式" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Button>

                    <Separator />

                    <TextBlock Text="网站：" VerticalAlignment="Center" Margin="0,0,0,0"/>
                    <ComboBox Width="150" Margin="5,0" materialDesign:HintAssist.Hint="选择网站">
                        <ComboBoxItem Content="百度" />
                        <ComboBoxItem Content="谷歌" />
                        <ComboBoxItem Content="必应" />
                    </ComboBox>

                    <Separator />

                    <Button ToolTip="图校模式" Padding="4" Click="OpenImageReview_Click">
                        <StackPanel Orientation="Horizontal">
                            <materialDesign:PackIcon Kind="ImageEdit" VerticalAlignment="Center" />
                            <TextBlock Text="图校模式" VerticalAlignment="Center" Margin="0,0,0,0"/>
                        </StackPanel>
                    </Button>

                </ToolBar>
            </ToolBarTray>
            <Grid ShowGridLines="False">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Margin="5" Background="#22000000">
                    <DockPanel>
                        <ToolBarTray DockPanel.Dock="Bottom" Background="Transparent">
                            <ToolBar Style="{StaticResource MaterialDesignToolBar}">
                                <!-- 使用 Grid 来模拟 WinForms 的 Dock 布局 (左对齐 + 右对齐) -->
                                <Grid Width="{Binding ActualWidth, RelativeSource={RelativeSource AncestorType=ToolBar}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- 左侧：图片适配按钮 -->
                                        <ColumnDefinition Width="*"/>
                                        <!-- 中间空白占位 -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- 右侧：图集信息 -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- 右侧：文件夹按钮 -->
                                        <ColumnDefinition Width="Auto"/>
                                        <!-- 右侧：翻页按钮 -->
                                    </Grid.ColumnDefinitions>

                                    <!-- 1. 左侧：图片适配 (对应 PicFitPanel) -->
                                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                                        <Button ToolTip="适应视图" Padding="4" >
                                            <materialDesign:PackIcon Kind="FitToPage" />
                                        </Button>
                                        <Button ToolTip="适应宽度" Padding="4" >
                                            <materialDesign:PackIcon Kind="ArrowExpandHorizontal" />
                                        </Button>
                                        <Button ToolTip="适应高度" Padding="4" >
                                            <materialDesign:PackIcon Kind="ArrowExpandVertical" />
                                        </Button>

                                        <Separator Margin="8,0"/>

                                        <Button ToolTip="锁定X" Padding="4" >
                                            <materialDesign:PackIcon Kind="LockOpen" />
                                        </Button>
                                        <Button ToolTip="锁定Y" Padding="4" >
                                            <materialDesign:PackIcon Kind="LockOpen" />
                                        </Button>
                                    </StackPanel>

                                    <!-- 2. 右侧区域：图集信息 (对应 PicNameLabel 和 PicName) -->
                                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="图集:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                        <ComboBox Width="150" 
                                                  materialDesign:HintAssist.Hint="选择图片" 
                                                  VerticalAlignment="Center"
                                                  FontSize="12">
                                            <ComboBoxItem Content="Image_001.jpg" />
                                            <ComboBoxItem Content="Image_002.jpg" />
                                        </ComboBox>
                                    </StackPanel>

                                    <Separator Grid.Column="2" Margin="10,0"/>

                                    <!-- 3. 右侧：文件夹按钮 (对应 WorkforlderOpen) -->
                                    <Button Grid.Column="3" 
                                            ToolTip="打开工作文件夹" 
                                            Padding="8,4" 
                                            Margin="0,0,5,0"
                                            >
                                        <StackPanel Orientation="Horizontal">
                                            <materialDesign:PackIcon Kind="FolderOpen" VerticalAlignment="Center" Margin="0,0,5,0"/>
                                            <TextBlock Text="文件夹" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>

                                    <!-- 4. 右侧：翻页按钮 (对应 LPbutton 和 NPbutton) -->
                                    <StackPanel Grid.Column="4" Orientation="Horizontal">
                                        <Button ToolTip="上一张" Width="30" Height="30" Padding="0" >
                                            <materialDesign:PackIcon Kind="ArrowUp" />
                                        </Button>
                                        <Button ToolTip="下一张" Width="30" Height="30" Padding="0" >
                                            <materialDesign:PackIcon Kind="ArrowDown" />
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </ToolBar>
                        </ToolBarTray>

                        <Image Source="{Binding SelectedImage.ImageSource}" 
                               Stretch="Uniform"
                               RenderOptions.BitmapScalingMode="HighQuality" />

                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch" 
                      Background="#eee" />

                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="*" />
                        <RowDefinition Height="5" />
                        <RowDefinition Height="200" />
                    </Grid.RowDefinitions>

                    <DataGrid x:Name="LabelDataGrid"
                        ItemsSource="{Binding SelectedImage.Labels}"
                        AutoGenerateColumns="False"
                        CanUserAddRows="False"
                        SelectionMode="Single"
                        GridLinesVisibility="Horizontal"
                        HeadersVisibility="Column">

                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号" Binding="{Binding Index}" IsReadOnly="True" Width="80"/>

                            <DataGridTextColumn Header="内容" Binding="{Binding Text, UpdateSourceTrigger=PropertyChanged}" Width="*"/>

                            <DataGridTextColumn Header="组" Binding="{Binding Group}" Width="80"/>

                        </DataGrid.Columns>
                    </DataGrid>

                    <GridSplitter Grid.Row="1" 
                          Height="5" 
                          HorizontalAlignment="Stretch" 
                          VerticalAlignment="Stretch" 
                          Background="#eee" />

                    <TextBox Grid.Row="2" Margin="5" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True" 
                     Style="{StaticResource MaterialDesignOutlinedTextBox}" />
                </Grid>
            </Grid>
        </DockPanel>
        <local:ImageReView x:Name="FullScreenReview" 
                       Visibility="Collapsed" 
                       Background="White" 
                       ExitClicked="FullScreenReview_ExitClicked" Grid.ColumnSpan="2"/>
    </Grid>
</Window>
