<Window x:Class="LabelMinusinWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:LabelMinusinWPF"
        mc:Ignorable="d"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes" 
        Title="LabelMinus" Height="800" Width="1200">
    <Window.Resources>
        <Style TargetType="StackPanel">
            <Setter Property="Orientation"
            Value= "Horizontal" />
        </Style>
    </Window.Resources>
    <Window.DataContext>
        <local:MainViewModel />
    </Window.DataContext>
    <Grid x:Name="RootGrid">
        <DockPanel Grid.ColumnSpan="2">
            <!-- 菜单栏 -->
            <Menu x:Name="Menu" FontFamily="微软雅黑" FontWeight="Bold"
                  DockPanel.Dock="Top" 
                  Background="{DynamicResource MaterialDesignPaper}"
                  Foreground="{DynamicResource MaterialDesignBody}"
                  materialDesign:MenuAssist.TopLevelMenuItemHeight="25"
                  FontSize="12">
                <!-- 1. 文件 -->
                <MenuItem Header="文件">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="File"/>
                    </MenuItem.Icon>

                    <!-- 新建 -->
                    <MenuItem Header="新建">
                        <MenuItem Header="新建翻译"
                                  InputGestureText="Ctrl+N" />
                        <MenuItem Header="新建压缩包翻译" />
                        <MenuItem.Icon>
                            <materialDesign:PackIcon Kind="FilePlus" />
                        </MenuItem.Icon>
                    </MenuItem>

                    <Separator />

                    <!-- 翻译相关 -->
                    <MenuItem Header="打开翻译" Command="{Binding OpenTranslationCommand}"/>
                    <MenuItem Header="保存翻译"/>
                    <MenuItem Header="翻译另存为..." />

                    <Separator />

                    <!-- 图片相关 -->
                    <MenuItem Header="打开图片/压缩包" Command="{Binding OpenImageCommand}"/>
                    <MenuItem Header="打开图片文件夹" />

                    <Separator />

                    <MenuItem Header="打开当前文件夹" />
                </MenuItem>

                <!-- 2. 修改 -->
                <MenuItem Header="修改">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Pencil"/>
                    </MenuItem.Icon>

                    <!-- 来自 WinForms 版本的具体业务功能 -->
                    <MenuItem Header="关联压缩包" />
                    <MenuItem Header="调整图集" />
                    <MenuItem Header="组别" />

                    <Separator />

                    <MenuItem Header="文本框字号" />
                    <MenuItem Header="OCR网站" />

                    <Separator />

                    <!-- 通用编辑功能 -->
                    <MenuItem Header="撤销" Command="Undo" />
                    <MenuItem Header="重做" Command="Redo" />
                </MenuItem>

                <!-- 3. 导出文本 -->
                <MenuItem Header="导出文本">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Export"/>
                    </MenuItem.Icon>

                    <!-- 来自 WinForms 版本的内容导出 -->
                    <MenuItem Header="导出原翻译" />
                    <MenuItem Header="导出现翻译" />
                    <MenuItem Header="导出修改文档" />

                    <Separator />

                    <!-- 来自 WPF 版本的格式导出 -->
                    <MenuItem Header="导出为TXT" />
                    <MenuItem Header="导出为Excel" />
                </MenuItem>

                <!-- 4. 显示 -->
                <MenuItem Header="显示">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Monitor"/>
                    </MenuItem.Icon>

                    <!-- 布局模式 (WinForms) -->
                    <MenuItem Header="列表与文本框" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="仅列表" IsCheckable="True" />
                    <MenuItem Header="仅文本框" IsCheckable="True" />

                    <Separator />

                    <!-- 视图选项 (WinForms) -->
                    <MenuItem Header="次要参数" IsCheckable="True" />
                    <MenuItem Header="列表序号" IsCheckable="True" IsChecked="True" />
                    <MenuItem Header="列表组别" IsCheckable="True" IsChecked="True" />
                    <MenuItem x:Name="MenuShowIndex" Header="图片序号" IsCheckable="True" IsChecked="{Binding IsPictureIndexVisible}" />
                    <MenuItem x:Name="MenuShowText" Header="图片文本" IsCheckable="True" IsChecked="{Binding IsPictureTextVisible}" />
                    <MenuItem Header="流畅图片显示" IsCheckable="True" IsChecked="True" />

                    <Separator />

                    <!-- 缩放与全屏 (WPF) -->
                    <MenuItem Header="全屏"/>
                    <MenuItem Header="放大"/>
                    <MenuItem Header="缩小"/>
                </MenuItem>

                <!-- 5. 高级 -->
                <MenuItem Header="高级">
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Cogs"/>
                    </MenuItem.Icon>
                    <MenuItem Header="设置" />
                    <MenuItem Header="插件管理" />
                </MenuItem>

                <!-- 6. 帮助 -->
                <MenuItem Header="帮助" >
                    <MenuItem.Icon>
                        <materialDesign:PackIcon Kind="Help"/>
                    </MenuItem.Icon>
                    <MenuItem Header="官网" />
                    <MenuItem Header="关于" />
                </MenuItem>

            </Menu>
            <!-- 顶栏 -->
            <Border DockPanel.Dock="Top" Height="35" 
                    Background="{DynamicResource MaterialDesignPaper}">
                
                <Grid Margin="10,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ChangeModeCommand}"
                            CommandParameter="{x:Static local:AppMode.See}"
                            Tag="Eye" 
                            Content="浏览" 
                            ToolTip="浏览图片"/>

                        <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ChangeModeCommand}"
                            CommandParameter="{x:Static local:AppMode.LabelDo}"
                            Tag="FileEdit" 
                            Content="标记" 
                            ToolTip="标记图片"/>
                        <!-- 识别模式与网站栏-->
                        <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ChangeModeCommand}"
                            CommandParameter="{x:Static local:AppMode.OCR}"
                            Tag="ImageSearch" 
                            Content="识别" 
                            ToolTip="内容识别"/>
                        <StackPanel>
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:AppMode.OCR}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ComboBox Width="150" Height="35" materialDesign:HintAssist.Hint="选择网站">
                                    <ComboBoxItem Content="百度" />
                                    <ComboBoxItem Content="谷歌" />
                                    <ComboBoxItem Content="必应" />
                                </ComboBox>
                        </StackPanel>
                        
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <Button Style="{StaticResource IconButtonStyle}"
                            Click="OpenImageReview_Click"
                            Tag="Compare" 
                            Content="图校" 
                            ToolTip="图片对比"/>
                        <ToggleButton Cursor="Hand"
                                      ToolTip="切换深色模式"
                                      Checked="DarkMode_Checked"
                                      Unchecked="DarkMode_Unchecked"
                                      VerticalAlignment="Center">
                            <materialDesign:PackIcon Kind="WeatherNight" Width="20" Height="20" />
                        </ToggleButton>
                    </StackPanel>
                </Grid>
            </Border>
            <!-- 主界面 -->
            <Grid ShowGridLines="False" ToolBar.OverflowMode="Never">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="5" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <!-- 左侧图片与底栏 -->
                <Border Grid.Column="0" Background="{DynamicResource MaterialDesignPaper}">

                    <DockPanel>
                        <ToolBar DockPanel.Dock="Bottom"
                                 Style="{StaticResource MaterialDesignToolBar}"
                                 Height="36">

                            <Button ToolTip="适应视图" Padding="4" Click="ResetView_Click">
                                <materialDesign:PackIcon Kind="FitToPage" />
                            </Button>
                            <Button ToolTip="适应宽度" Padding="4">
                                <materialDesign:PackIcon Kind="ArrowExpandHorizontal" />
                            </Button>
                            <Button ToolTip="适应高度" Padding="4">
                                <materialDesign:PackIcon Kind="ArrowExpandVertical" />
                            </Button>

                            <Button ToolTip="锁定X" Padding="4">
                                <materialDesign:PackIcon Kind="ArrowHorizontalLock" />
                            </Button>
                            <Button ToolTip="锁定Y" Padding="4">
                                <materialDesign:PackIcon Kind="ArrowVerticalLock" />
                            </Button>
                            <Separator/>
                            <Button Style="{StaticResource IconButtonStyle}"
                            Command="{Binding ChangeModeCommand}"
                            CommandParameter="{x:Static local:AppMode.LabelDo}"
                            Tag="FolderMultipleImage" 
                            Content="文件夹" 
                            ToolTip="打开工作文件夹"/>
                            <Separator/>
                            <StackPanel Margin="5,0">
                                <materialDesign:PackIcon Kind="ImageMultiple" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <ComboBox Width="100" 
                                            ItemsSource="{Binding ImageList}"
                                            SelectedItem="{Binding SelectedImage}"
                                            DisplayMemberPath="ImageName"
                                            materialDesign:HintAssist.Hint="选择图片" 
                                            VerticalAlignment="Center"
                                            FontSize="12" >
                                </ComboBox>
                            </StackPanel>
                            <StackPanel>
                                <Button ToolTip="上一张" Command="{Binding PreviousImageCommand}"  Padding="4">
                                    <materialDesign:PackIcon Kind="ArrowUp" />
                                </Button>
                                <Button ToolTip="下一张" Command="{Binding NextImageCommand}"  Padding="4">
                                    <materialDesign:PackIcon Kind="ArrowDown" />
                                </Button>
                            </StackPanel>

                        </ToolBar>
                        <!-- 图片！！！！！ -->
                        <Grid x:Name="ImageParent" ClipToBounds="True"
                                MouseWheel="ImageParent_MouseWheel"
                                MouseDown="ImageParent_MouseDown"
                                MouseUp="ImageParent_MouseUp"
                                MouseMove="ImageParent_MouseMove">
                            <Grid RenderTransformOrigin="0,0">
                                <Grid.RenderTransform>
                                    <TransformGroup>
                                        <ScaleTransform x:Name="ImageScale" />
                                        <TranslateTransform x:Name="ImageTranslate" />
                                    </TransformGroup>
                                </Grid.RenderTransform>
                                <!-- 图片与标签显示控件！！！！！ -->
                                <local:ImagewithLabelShow 
                                    x:Name="PicView"
                                    DataContext="{Binding SelectedImage}" 
                                    IsIndexVisible="{Binding IsChecked, ElementName=MenuShowIndex}"
                                    IsTextVisible="{Binding IsChecked, ElementName=MenuShowText}" 
                                    RequestDragImage="MyLabelControl_RequestDragImage"/>
                            </Grid>
                            <!--截图控件,要与上面的grid平行-->
                            <Canvas x:Name="SnipCanvas" Background="#55000000"
                                    MouseDown="SnipCanvas_MouseDown"       
                                    MouseMove="SnipCanvas_MouseMove"                                 
                                    MouseUp="SnipCanvas_MouseUp">
                                <Canvas.Style>
                                    <Style TargetType="Canvas">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Setter Property="IsHitTestVisible" Value="False"/>

                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding CurrentMode}" Value="{x:Static local:AppMode.OCR}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                                <Setter Property="IsHitTestVisible" Value="True"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Canvas.Style>

                                <Rectangle x:Name="SnipRectangle" 
                                           Stroke="RoyalBlue" 
                                           StrokeThickness="2" 
                                           StrokeDashArray="4 4"
                                           Visibility="Collapsed"/>
                            </Canvas>
                        </Grid>

                    </DockPanel>
                </Border>

                <GridSplitter Grid.Column="1" 
                      Width="5" 
                      HorizontalAlignment="Stretch" 
                      VerticalAlignment="Stretch"/>
                <!-- 右侧列表与文本 -->
                <Grid Grid.Column="2" Background="RoyalBlue">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="3*"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DataGrid x:Name="LabelDataGrid"
                              Style="{StaticResource MaterialDesignDataGrid}"
                                ItemsSource="{Binding SelectedImage.Labels}"
                                SelectedItem="{Binding SelectedImage.SelectedLabel, Mode=TwoWay}" 
                                AutoGenerateColumns="False"
                                CanUserAddRows="False"
                                SelectionMode="Single"
                                GridLinesVisibility="Horizontal"
                                HeadersVisibility="Column"
                              Margin="4">
                        <DataGrid.RowStyle>
                            <Style TargetType="DataGridRow" BasedOn="{StaticResource MaterialDesignDataGridRow}">
                                <Style.Triggers>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter Property="FontWeight" Value="Bold" />
                                        <Setter Property="BorderThickness" Value="1"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </DataGrid.RowStyle>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="序号" Binding="{Binding Index}" IsReadOnly="True" Width="80"/>
                            <!-- 高级文本编辑 -->
                            <DataGridTemplateColumn Header="内容" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>

                                <DataGridTemplateColumn.CellEditingTemplate>
                                    <DataTemplate>
                                        <TextBox Text="{Binding Text, UpdateSourceTrigger=PropertyChanged}"
                                                 TextWrapping="Wrap"
                                                 AcceptsReturn="True" 
                                                 BorderThickness="0"
                                                 Padding="2"
                                                 Background="White"
                                                 Foreground="Black"
                                                 VerticalContentAlignment="Top"
                                                 Style="{x:Null}" />
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellEditingTemplate>
                            </DataGridTemplateColumn>

                            <DataGridTextColumn Header="组" Binding="{Binding Group}" Width="80"/>
                            <DataGridTextColumn Header="X" Binding="{Binding X}" Width="50"/>
                            <DataGridTextColumn Header="Y" Binding="{Binding Y}" Width="40"/>

                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBox Grid.Row="1" 
                             Text="{Binding SelectedImage.SelectedLabel.Text, UpdateSourceTrigger=PropertyChanged}"
                             Style="{StaticResource MaterialDesignOutlinedTextBox}"
                             Background="{StaticResource MaterialDesignPaper}"
                             FontSize="16"
                             HorizontalContentAlignment="Left"
                             VerticalContentAlignment="Top"
                             TextAlignment="Left"/>


                </Grid>
            </Grid>
        </DockPanel>
        <!-- 图校界面 -->
        <local:ImageReView x:Name="FullScreenReview" 
                           Visibility="Collapsed" 
                           ExitClicked="FullScreenReview_ExitClicked" Grid.ColumnSpan="2"/>
    </Grid>
</Window>
