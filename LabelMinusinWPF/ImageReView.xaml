<UserControl x:Class="LabelMinusinWPF.ImageReView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LabelMinusinWPF"
             mc:Ignorable="d" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="#FFF5E6"
             d:DesignHeight="450" d:DesignWidth="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="更换图片" Margin="2"/>

            <UniformGrid Grid.Column="1" Rows="2" Columns="1" Margin="5,0">
                <Button Content="选择图片/压缩包" Margin="2"/>
                <Button Content="选择文件夹" Margin="2"/>
            </UniformGrid>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button Content="截图(Q)" Height="60" Width="80" Margin="5"/>
                <StackPanel>
                    <TextBlock Text="截图自动复制到剪贴板" HorizontalAlignment="Center"/>
                    <ComboBox Width="180" Margin="0,5"/>
                </StackPanel>
                <Button Content="上一张" Height="60" Margin="5"/>
                <Button Content="下一张" Height="60" Margin="5"/>
            </StackPanel>

            <UniformGrid Grid.Column="3" Rows="2" Columns="1" Margin="5,0">
                <Button Content="选择图片/压缩包" Margin="2"/>
                <Button Content="选择文件夹" Margin="2"/>
            </UniformGrid>

            <Button Grid.Column="4" Content="更换图片" Margin="2"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="Transparent">
                <Image x:Name="LeftImage" Stretch="Uniform"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="点击此处选择图片/压缩包" FontSize="18" Foreground="#888" HorizontalAlignment="Center"/>
                    <TextBlock Text="Q(按住)：截图&#x0a;A：上一张&#x0a;D：下一张&#x0a;R：重置显示" 
                               TextAlignment="Center" Margin="0,10" Foreground="#888" LineHeight="25"/>
                    <TextBlock Text="截图后可红笔进行标记(清空限当次标记)" Foreground="#A55" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Column="1" Fill="#FFDAB9" Width="2"/>

            <Grid Grid.Column="2" Background="Transparent">
                <Image x:Name="RightImage" Stretch="Uniform"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="点击此处选择图片/压缩包" FontSize="18" Foreground="#888" HorizontalAlignment="Center"/>
                    <TextBlock Text="Q(按住)：截图&#x0a;A：上一张&#x0a;D：下一张&#x0a;R：重置显示" 
                               TextAlignment="Center" Margin="0,10" Foreground="#888" LineHeight="25"/>
                    <TextBlock Text="截图后可红笔进行标记(清空限当次标记)" Foreground="#A55" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="适应屏幕" Margin="2"/>
            <Button Grid.Column="1" Content="打开截图文件夹" Margin="2"/>

            <TextBlock Grid.Column="2" Text="左键标注&#x0a;右键清空" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5,0"/>
            <Border Grid.Column="3" Width="80" Height="40" Background="#FFDAB9" BorderBrush="#888" BorderThickness="1" Margin="5,0"/>

            <Button Grid.Column="4" Content="同步显示" Background="#90EE90" Width="100" HorizontalAlignment="Left" Margin="5,0"/>

            <StackPanel Grid.Column="5" Orientation="Horizontal">
                <TextBlock Text="支持多选图片&#x0a;支持选择.zip/.7z/.rar压缩包" VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
                <Button Content="清空图片" Margin="2"/>
                <Button x:Name="ExitBtn" Content="退出图校" Margin="2" Background="#FF4444" Foreground="White" Click="ExitBtn_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>
