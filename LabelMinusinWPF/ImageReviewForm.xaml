<UserControl x:Class="LabelMinusinWPF.ImageReView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:LabelMinusinWPF"
             mc:Ignorable="d" 
             xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
             Background="{DynamicResource MaterialDesignPaper}"
             d:DesignHeight="800" d:DesignWidth="1200">
<UserControl.Resources>
    <Style x:Key="BorderedButtonStyle"
        TargetType="Button"
        BasedOn="{StaticResource MaterialDesignFlatButton}">
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="BorderBrush"
            Value="{DynamicResource MaterialDesignDivider}"/>
    </Style>
</UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 更换图片 -->
            <Button VerticalAlignment="Bottom" Grid.Column="0" Margin="2" Padding="8,4" ToolTip="更换当前图片&#x0A;(不影响图集)">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileImage"/>
                </StackPanel>
            </Button>

            <UniformGrid Grid.Column="1" Rows="2" Columns="1" Margin="5,0">
                <!-- 选择图片/压缩包 -->
                <Button Margin="2" HorizontalAlignment="Left" Width="180" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ImageMultiple" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="选择图片/压缩包" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 选择文件夹 -->
                <Button Margin="2" HorizontalAlignment="Left" Width="180" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="选择文件夹" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <!-- 截图 -->
                <Button Height="60" Width="100" Margin="5" Padding="5">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Camera" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="截图(Q)" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <StackPanel>
                    <TextBlock Text="截图自动复制到剪贴板" HorizontalAlignment="Center"/>
                    <ComboBox Width="180" Margin="0,5"/>
                </StackPanel>
                <!-- 上一张 -->
                <Button Height="60" Margin="5" Padding="8,4" ToolTip="上一张">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowUp" Width="30" Height="36"/>
                    </StackPanel>
                </Button>
                <!-- 下一张 -->
                <Button Height="60" Margin="5" Padding="8,4" ToolTip="下一张">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ArrowDown" Width="30" Height="36"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <UniformGrid Grid.Column="3" Rows="2" Columns="1" Margin="5,0">
                <!-- 选择图片/压缩包 -->
                <Button Margin="2" HorizontalAlignment="Right" Width="180" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="ImageMultiple" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="选择图片/压缩包" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 选择文件夹 -->
                <Button Margin="2" HorizontalAlignment="Right" Width="180" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="FolderOpen" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="选择文件夹" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </UniformGrid>

            <!-- 更换图片 -->
            <Button VerticalAlignment="Bottom" Grid.Column="4" Margin="2" Padding="8,4" ToolTip="更换当前图片&#x0A;(不影响图集)">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FileImage"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="2"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Background="Transparent">
                <Image x:Name="LeftImage" Stretch="Uniform"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="点击此处选择图片/压缩包" FontSize="18" Foreground="#888" HorizontalAlignment="Center"/>
                    <TextBlock Text="Q(按住)：截图&#x0a;A：上一张&#x0a;D：下一张&#x0a;R：重置显示" 
                               TextAlignment="Center" Margin="0,10" Foreground="#888" LineHeight="25"/>
                    <TextBlock Text="截图后可红笔进行标记(清空限当次标记)" Foreground="#A55" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>

            <Rectangle Grid.Column="1" Fill="#FFDAB9" Width="2"/>

            <Grid Grid.Column="2" Background="Transparent">
                <Image x:Name="RightImage" Stretch="Uniform"/>
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" IsHitTestVisible="False">
                    <TextBlock Text="点击此处选择图片/压缩包" FontSize="18" Foreground="#888" HorizontalAlignment="Center"/>
                    <TextBlock Text="Q(按住)：截图&#x0a;A：上一张&#x0a;D：下一张&#x0a;R：重置显示" 
                               TextAlignment="Center" Margin="0,10" Foreground="#888" LineHeight="25"/>
                    <TextBlock Text="截图后可红笔进行标记(清空限当次标记)" Foreground="#A55" HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Grid>

        <Grid Grid.Row="2" Margin="5">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 适应屏幕 -->
            <Button Grid.Column="0" Margin="2" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FitToPage" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="适应屏幕" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
            <!-- 打开截图文件夹 -->
            <Button Grid.Column="1" Margin="2" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="FolderImage" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="打开截图文件夹" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <TextBlock Grid.Column="2" Text="左键标注&#x0a;右键清空" VerticalAlignment="Center" HorizontalAlignment="Right" Margin="5,0"/>
            <Border Grid.Column="3" Width="80" Height="40" Background="#FFDAB9" BorderBrush="#888" BorderThickness="1" Margin="5,0"/>

            <!-- 同步显示 -->
            <Button Grid.Column="4" Background="#90EE90" Width="120" HorizontalAlignment="Left" Margin="5,0" Padding="8,4">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Sync" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <TextBlock Text="同步显示" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <StackPanel Grid.Column="5" Orientation="Horizontal">
                <TextBlock Text="支持多选图片&#x0a;支持选择.zip/.7z/.rar压缩包" VerticalAlignment="Center" Margin="10,0" FontSize="11"/>
                <!-- 清空图片 -->
                <Button Margin="2" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Delete" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="清空图片" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <!-- 退出图校 -->
                <Button x:Name="ExitBtn" Margin="2" Background="#FF4444" Foreground="White" Click="ExitBtn_Click" Padding="8,4">
                    <StackPanel Orientation="Horizontal">
                        <materialDesign:PackIcon Kind="Close" VerticalAlignment="Center" Margin="0,0,5,0"/>
                        <TextBlock Text="退出图校" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>
        </Grid>
    </Grid>
</UserControl>